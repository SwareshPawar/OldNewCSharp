@page "/auth/reset-password"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavigationManager
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json

<PageTitle>Reset Password</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-body">
                    <h3 class="card-title text-center mb-4">Reset Password</h3>

                    @if (!string.IsNullOrEmpty(StatusMessage))
                    {
                        <div class="alert @(IsError ? "alert-danger" : "alert-success")" role="alert">
                            @StatusMessage
                        </div>
                    }

                    @if (IsLoading)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else if (!HasRequiredQuery)
                    {
                        <div class="alert alert-danger" role="alert">
                            Invalid or missing reset link.
                        </div>
                    }
                    else if (IsDone)
                    {
                        <div class="text-center">
                            <button class="btn btn-primary" @onclick='() => NavigationManager.NavigateTo("/auth/login")'>Go to Login</button>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="Model" OnValidSubmit="HandleReset">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label for="newPassword" class="form-label">New Password</label>
                                <InputText id="newPassword" type="password" @bind-Value="Model.NewPassword" class="form-control" />
                                <ValidationMessage For="@(() => Model.NewPassword)" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label for="confirmPassword" class="form-label">Confirm Password</label>
                                <InputText id="confirmPassword" type="password" @bind-Value="Model.ConfirmPassword" class="form-control" />
                                <ValidationMessage For="@(() => Model.ConfirmPassword)" class="text-danger" />
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">Reset Password</button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool IsLoading;
    private bool IsDone;
    private bool IsError;
    private bool HasRequiredQuery;
    private string? StatusMessage;
    private string UserId = string.Empty;
    private string Token = string.Empty;

    private ResetPasswordModel Model = new();

    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        query.TryGetValue("userId", out var userId);
        query.TryGetValue("token", out var token);

        HasRequiredQuery = !string.IsNullOrWhiteSpace(userId)
            && !string.IsNullOrWhiteSpace(token);

        if (HasRequiredQuery)
        {
            UserId = userId.ToString();
            Token = token.ToString();
        }
    }

    private async Task HandleReset()
    {
        IsLoading = true;
        StatusMessage = null;
        IsError = false;

        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/reset-password", new
            {
                userId = UserId,
                token = Token,
                newPassword = Model.NewPassword
            });

            if (response.IsSuccessStatusCode)
            {
                IsDone = true;
                StatusMessage = "Password reset successful. You can now sign in.";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                IsError = true;
                StatusMessage = string.IsNullOrWhiteSpace(error)
                    ? "Failed to reset password."
                    : error;
            }
        }
        catch (Exception ex)
        {
            IsError = true;
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private class ResetPasswordModel
    {
        [Required]
        [MinLength(6)]
        public string NewPassword { get; set; } = string.Empty;

        [Required]
        [Compare(nameof(NewPassword))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
