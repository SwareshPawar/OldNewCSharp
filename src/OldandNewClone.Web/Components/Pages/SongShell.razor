    private void AppendLyricsTag(bool isEditTarget, string tag)
    {
        if (isEditTarget)
        {
            editSong.Lyrics = AppendTag(editSong.Lyrics, tag);
            return;
        }

        newSong.Lyrics = AppendTag(newSong.Lyrics, tag);
    }

    private static string AppendTag(string? current, string tag)
    {
        if (string.IsNullOrWhiteSpace(current))
            return tag + Environment.NewLine;

        var suffix = current.EndsWith(Environment.NewLine, StringComparison.Ordinal) ? string.Empty : Environment.NewLine + Environment.NewLine;
        return current + suffix + tag + Environment.NewLine;
    }

    private readonly List<DateTime> _tapTempoSamples = new();

    private void TapTempo(bool isEditTarget)
    {
        var now = DateTime.UtcNow;
        _tapTempoSamples.Add(now);
        _tapTempoSamples.RemoveAll(t => (now - t).TotalSeconds > 5);

        if (_tapTempoSamples.Count < 2)
            return;

        var intervals = new List<double>();
        for (var index = 1; index < _tapTempoSamples.Count; index++)
            intervals.Add((_tapTempoSamples[index] - _tapTempoSamples[index - 1]).TotalMilliseconds);

        var averageMs = intervals.Average();
        if (averageMs <= 0)
            return;

        var bpm = (int)Math.Round(60000d / averageMs);
        if (isEditTarget)
            editSong.Tempo = bpm.ToString();
        else
            newSong.Tempo = bpm.ToString();
    }

