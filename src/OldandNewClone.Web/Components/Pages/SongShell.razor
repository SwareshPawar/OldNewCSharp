    private void ToggleAutoScroll()
    {
        if (isAutoScrolling)
        {
            _scrollCts?.Cancel();
            _scrollCts = null;
            isAutoScrolling = false;
        }
        else
        {
            isAutoScrolling = true;
            _scrollCts = new CancellationTokenSource();
            var token = _scrollCts.Token;
            _ = Task.Run(async () =>
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(50, token).ConfigureAwait(false);
                    await InvokeAsync(async () =>
                    {
                        await JS.InvokeVoidAsync("oldnewSongShell.scrollById", "lyrics-scroll-panel", 1);
                    });
                }
            }, token);
        }
    }

    private static readonly string[] ChordRoots = { "C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B" };
    private static readonly Dictionary<string, string> FlatToSharp = new() { {"Db","C#"},{"Eb","D#"},{"Fb","E"},{"Gb","F#"},{"Ab","G#"},{"Bb","A#"},{"Cb","B"} };
    private static readonly Regex ChordRegex = new(@"([A-G][#b]?)(maj7?|min|m7?|dim|aug|sus[24]?|add9|m9|maj9|7|9|11|13|6)?(?:\/([A-G][#b]?))?", RegexOptions.Compiled);
    private static readonly Regex ChordLineRegex = new(@"^(\s*[A-G][#b]?(?:maj7?|min|m7?|dim|aug|sus[24]?|add9|m9|maj9|7|9|11|13|6)?(?:\/[A-G][#b]?)?\s*)+$", RegexOptions.Compiled | RegexOptions.IgnoreCase);
    private static readonly Regex InlineChordRegex = new(@"\[([A-G][#b]?(?:maj7?|min|m7?|dim|aug|sus[24]?|add9|m9|maj9|7|9|11|13|6)?(?:\/[A-G][#b]?)?)\]", RegexOptions.Compiled);

    private static string TransposeSingleRoot(string root, int steps)
    {
        if (FlatToSharp.TryGetValue(root, out var sharp)) root = sharp;
        var idx = Array.IndexOf(ChordRoots, root);
        if (idx < 0) return root;
        return ChordRoots[((idx + steps) % 12 + 12) % 12];
    }

    private static string TransposeChordSymbol(string chord, int steps)
    {
        if (steps == 0 || string.IsNullOrWhiteSpace(chord)) return chord;

        var match = ChordRegex.Match(chord);
        if (!match.Success) return chord;

        var root = match.Groups[1].Value;
        var quality = match.Groups[2].Value;
        var bass = match.Groups[3].Success ? match.Groups[3].Value : null;

        var newRoot = TransposeSingleRoot(root, steps);
        var newBass = bass is null ? null : TransposeSingleRoot(bass, steps);

        return newBass is null ? $"{newRoot}{quality}" : $"{newRoot}{quality}/{newBass}";
    }

    private static string RenderLyricsWithChords(string lyrics, int steps)
    {
        if (string.IsNullOrWhiteSpace(lyrics)) return string.Empty;
        var lines = lyrics.Replace("\r\n", "\n").Replace("\r", "\n").Split('\n');
        var sb = new System.Text.StringBuilder();
        foreach (var line in lines)
        {
            if (string.IsNullOrWhiteSpace(line))
            {
                sb.AppendLine();
                continue;
            }

            if (InlineChordRegex.IsMatch(line))
            {
                var rendered = InlineChordRegex.Replace(line, m =>
                {
                    var orig = m.Groups[1].Value;
                    var transposed = TransposeChordSymbol(orig, steps);
                    return $"<span class=\"inline-chord\">[{System.Web.HttpUtility.HtmlEncode(transposed)}]</span>";
                });
                sb.AppendLine(rendered);
                continue;
            }

            if (!string.IsNullOrWhiteSpace(line) && ChordLineRegex.IsMatch(line.Trim()))
            {
                var transposed = steps == 0 ? line : ChordRegex.Replace(line, m => TransposeChordSymbol(m.Value, steps));
                sb.AppendLine($"<span class=\"chord-line\">{System.Web.HttpUtility.HtmlEncode(transposed)}</span>");
                continue;
            }

            sb.AppendLine(System.Web.HttpUtility.HtmlEncode(line));
        }
        return sb.ToString();
    }

