@if (showSetlistModal)
{
    <div class="song-modal-overlay" @onclick="CloseSetlistModal"></div>
    <div class="song-modal-container" role="dialog" aria-modal="true" tabindex="0" @onkeydown="HandleGlobalKeyDown">
        <div class="song-modal-header">
            <h3>@(isEditSetlistModal ? "✏️ Edit Setlist" : "🗂️ New Setlist")</h3>
            <button class="song-modal-close" @onclick="CloseSetlistModal">✕</button>
        </div>

        <div class="song-modal-body">
            @if (setlistError != null)
            {
                <div class="form-error">⚠️ @setlistError</div>
            }

            <div class="form-group"><label>Name *</label><input @bind="setlistName" class="form-input" /></div>
            <div class="form-group"><label>Description</label><textarea @bind="setlistDescription" class="form-textarea" rows="4"></textarea></div>

            @if (IsSmartSetlistModal)
            {
                <div class="form-group">
                    <label>Categories (multi-select)</label>
                    <div class="multi-option-grid">
                        @foreach (var c in SmartCategoryOptions)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@smartSelectedCategories.Contains(c)"
                                       @onchange="e => ToggleSmartSelection(smartSelectedCategories, c, IsChecked(e))" />
                                <span>@c</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label>Keys (multi-select)</label>
                    <div class="multi-option-grid">
                        @foreach (var key in MusicKeys)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@smartSelectedKeys.Contains(key)"
                                       @onchange="e => ToggleSmartSelection(smartSelectedKeys, key, IsChecked(e))" />
                                <span>@key</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label>Moods (multi-select)</label>
                    <div class="multi-option-grid">
                        @foreach (var mood in Moods)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@smartSelectedMoods.Contains(mood)"
                                       @onchange="e => ToggleSmartSelection(smartSelectedMoods, mood, IsChecked(e))" />
                                <span>@mood</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label>Genres (multi-select)</label>
                    <div class="multi-option-grid">
                        @foreach (var genre in GenreOptions)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@smartSelectedGenres.Contains(genre)"
                                       @onchange="e => ToggleSmartSelection(smartSelectedGenres, genre, IsChecked(e))" />
                                <span>@genre</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label>Time Signatures (multi-select)</label>
                    <div class="multi-option-grid">
                        @foreach (var time in SmartTimeOptions)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@smartSelectedTimes.Contains(time)"
                                       @onchange="e => ToggleSmartSelection(smartSelectedTimes, time, IsChecked(e))" />
                                <span>@time</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label>Taals (multi-select)</label>
                    <div class="multi-option-grid">
                        @foreach (var taal in SmartTaalFilterOptions)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@smartSelectedTaals.Contains(taal)"
                                       @onchange="e => ToggleSmartSelection(smartSelectedTaals, taal, IsChecked(e))" />
                                <span>@taal</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label>Singers (multi-select)</label>
                    <div class="multi-option-grid">
                        @foreach (var singer in SmartSingerOptions)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@smartSelectedSingers.Contains(singer)"
                                       @onchange="e => ToggleSmartSelection(smartSelectedSingers, singer, IsChecked(e))" />
                                <span>@singer</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label>Tags (multi-select)</label>
                    <div class="multi-option-grid">
                        @foreach (var tag in SmartTagOptions)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@smartSelectedTags.Contains(tag)"
                                       @onchange="e => ToggleSmartSelection(smartSelectedTags, tag, IsChecked(e))" />
                                <span>@tag</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-group-row">
                    <div class="form-group">
                        <label>Tempo Min</label>
                        <input type="number" min="0" @bind="smartTempoMin" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Tempo Max</label>
                        <input type="number" min="0" @bind="smartTempoMax" class="form-input" />
                    </div>
                </div>

                <div class="smart-scan-toolbar">
                    <button class="btn-cancel-edit" @onclick="ScanSmartSetlistSongsPreview" disabled="@isSmartScanRunning">
                        @(isSmartScanRunning ? "Scanning..." : "Scan Songs")
                    </button>
                    @if (smartScanHasRun)
                    {
                        <span class="smart-scan-count">@smartScannedSongs.Count song(s) matched</span>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(smartScanDiagnostics))
                {
                    <div class="smart-scan-debug">@smartScanDiagnostics</div>
                }

                @if (!string.IsNullOrWhiteSpace(smartScanError))
                {
                    <div class="form-error">⚠️ @smartScanError</div>
                }

                @if (smartScanHasRun)
                {
                    <div class="smart-scan-results">
                        @if (smartScannedSongs.Count == 0)
                        {
                            <div class="manage-empty-hint">No songs matched the selected filters.</div>
                        }
                        else
                        {
                            @foreach (var song in smartScannedSongs)
                            {
                                <div class="smart-scan-row">
                                    <div class="manage-song-info">
                                        <span class="manage-song-title">@song.Title</span>
                                        @if (!string.IsNullOrWhiteSpace(song.Singer))
                                        {
                                            <span class="manage-song-meta">🎤 @song.Singer</span>
                                        }
                                    </div>
                                    <div class="manage-song-right">
                                        @if (!string.IsNullOrWhiteSpace(song.Key))
                                        {
                                            <span class="key-pill">@song.Key</span>
                                        }
                                        <span class="cat-dot @(song.Category == "Old" ? "dot-old" : "dot-new")"></span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
            }
        </div>

        <div class="song-modal-actions">
            <button @onclick="CloseSetlistModal" class="btn-cancel-edit">Cancel</button>
            <button @onclick="SaveSetlistFromModal" class="btn-save-song" disabled="@isSetlistSaving">
                @(isSetlistSaving ? "Saving..." : "💾 Save")
            </button>
        </div>
    </div>
}

@if (showManageSongsModal)
{
    <div class="song-modal-overlay" @onclick="CloseManageSongsModal"></div>
    <div class="song-modal-container manage-songs-modal" role="dialog" aria-modal="true" tabindex="0" @onkeydown="HandleGlobalKeyDown">
        <div class="song-modal-header">
            <h3>🎵 Manage Songs — @selectedSetlist?.Name</h3>
            <button class="song-modal-close" @onclick="CloseManageSongsModal">✕</button>
        </div>

        <div class="manage-songs-body">
            @if (manageSongsError != null)
            {
                <div class="form-error">⚠️ @manageSongsError</div>
            }

            <!-- Current setlist songs -->
            <div class="manage-section-label">
                <span>IN SETLIST <span class="manage-count-badge">@manageSongsList.Count</span></span>
            </div>
            @if (manageSongsList.Count == 0)
            {
                <div class="manage-empty-hint">No songs yet. Add some below.</div>
            }
            else
            {
                <div class="manage-setlist-songs">
                    @for (int i = 0; i < manageSongsList.Count; i++)
                    {
                        var idx = i;
                        var song = allSongs.FirstOrDefault(s => s.Id == manageSongsList[idx]);
                        if (song is null) continue;
                        <div class="manage-song-row">
                            <div class="manage-reorder-btns">
                                <button class="manage-order-btn" title="Move up" disabled="@(idx == 0)"
                                        @onclick="() => ManageSongsMoveUp(idx)">↑</button>
                                <button class="manage-order-btn" title="Move down" disabled="@(idx == manageSongsList.Count - 1)"
                                        @onclick="() => ManageSongsMoveDown(idx)">↓</button>
                            </div>
                            <div class="manage-song-info">
                                <span class="manage-song-title">@song.Title</span>
                                @if (!string.IsNullOrEmpty(song.Singer))
                                {
                                    <span class="manage-song-meta">🎤 @song.Singer</span>
                                }
                            </div>
                            <div class="manage-song-right">
                                @if (!string.IsNullOrEmpty(song.Key))
                                {
                                    <span class="key-pill">@song.Key</span>
                                }
                                <span class="cat-dot @(song.Category == "Old" ? "dot-old" : "dot-new")"></span>
                                <button class="manage-remove-btn" title="Remove from setlist"
                                        @onclick="() => ManageSongsRemove(song.Id)">🗑️</button>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Add songs section -->
            <div class="manage-section-label" style="margin-top:14px;">
                <span>ADD SONGS</span>
            </div>
            <input type="search" placeholder="🔍 Search to add..."
                   class="p2-search manage-add-search"
                   @bind="manageSongsSearchText" @bind:event="oninput" />

            <div class="manage-add-list">
                @{
                    var available = allSongs
                        .Where(s => !manageSongsList.Contains(s.Id))
                        .Where(s => string.IsNullOrEmpty(manageSongsSearchText) ||
                                    s.Title.Contains(manageSongsSearchText, StringComparison.OrdinalIgnoreCase) ||
