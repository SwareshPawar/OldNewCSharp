    private async Task HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            if (showSongModal)
            {
                CloseSongModal();
                return;
            }

            if (showSetlistModal)
            {
                CloseSetlistModal();
                return;
            }

            if (showManageSongsModal)
            {
                CloseManageSongsModal();
                return;
            }

            if (suggestedDrawerOpen)
                CloseSuggestedDrawer();

            return;
        }

        if (showSongModal || showSetlistModal || showManageSongsModal)
            return;

        var isInputFocused = await JS.InvokeAsync<bool>("oldnewSongShell.isInputFocused");
        if (isInputFocused)
            return;

        if (e.Key == "/")
        {
            await JS.InvokeVoidAsync("oldnewSongShell.focusSelector", ".p2-search");
            return;
        }

        if (string.Equals(e.Key, "n", StringComparison.OrdinalIgnoreCase) && UserState.IsLoggedIn)
        {
            OpenAddModal();
            return;
        }

        if (string.Equals(e.Key, "s", StringComparison.OrdinalIgnoreCase) && selectedSong is not null)
        {
            ToggleSuggestedDrawer();
            return;
        }

        if (string.Equals(e.Key, "f", StringComparison.OrdinalIgnoreCase) && selectedSong is not null && UserState.IsLoggedIn)
        {
            await ToggleFavorite();
            return;
        }

        if (string.Equals(e.Key, "e", StringComparison.OrdinalIgnoreCase) && selectedSong is not null && UserState.IsLoggedIn)
        {
            OpenEditModal();
            return;
        }

        if (e.Key == "+" || e.Key == "=")
        {
            IncreaseFontSize();
            return;
        }

        if (e.Key == "-")
        {
            DecreaseFontSize();
            return;
        }

        if (e.Key == "[")
        {
            TransposeDown();
            return;
        }

        if (e.Key == "]")
        {
            TransposeUp();
            return;
        }

        if (e.Key == "0")
            ResetTranspose();
    }

