    private const string PrefThemeKey = "oldnew:shell:theme";
    private const string PrefFontSizeKey = "oldnew:shell:fontSize";
    private const string PrefCategoryTabKey = "oldnew:shell:categoryTab";
    private const string PrefSectionKey = "oldnew:shell:section";
    private const string PrefSongIdKey = "oldnew:shell:songId";
    private const string PrefPanelKey = "oldnew:shell:panel";

    private int? persistedSongId;

    private string AppThemeLabel => appThemeMode switch
    {
        "light" => "Light",
        "dark" => "Dark",
        _ => "Auto"
    };

    private string AppThemeClass => appThemeMode switch
    {
        "light" => "theme-light",
        "dark" => "theme-dark",
        _ => "theme-light"
    };

    private SongFormModel editSong = new();
    private string editGenresText = "";
    private bool isSaving = false;
    private string? saveError;
    private bool saveSuccess = false;
    private SongFormModel newSong = new();
    private bool showSongModal = false;
    private bool isEditModal = false;

    private static readonly string[] MusicKeys =
        { "C","C#","D","D#","E","F","F#","G","G#","A","A#","B",
          "Cm","C#m","Dm","D#m","Em","Fm","F#m","Gm","G#m","Am","A#m","Bm" };

    private static readonly string[] Moods =
        { "Worship","Praise","Reflective","Joyful","Peaceful","Energetic","Devotional" };

    private int NewTabCount => GetSectionBase().Count(s => s.Category == "New");
    private int OldTabCount => GetSectionBase().Count(s => s.Category == "Old");
    private int AllTabCount => GetSectionBase().Count();
    private bool HasFilters => !string.IsNullOrEmpty(filterKey);

    private string SectionTitle => activeSection switch
    {
        "favorites" => "❤️ Favorites",
        "setlists-global" => "🌍 Global Setlists",
        "setlists-my" => "📋 My Setlists",
        "setlists-smart" => "🧠 Smart Setlists",
        _ => "🎵 All Songs"
    };

    private static readonly string[] KeyOrder = { "C","C#","D","D#","E","F","F#","G","G#","A","A#","B" };
    private static readonly string[] MinorOrder = { "Cm","C#m","Dm","D#m","Em","Fm","F#m","Gm","G#m","Am","A#m","Bm" };

    private string TransposedKey
    {
        get
        {
            if (selectedSong == null || transposeSteps == 0) return selectedSong?.Key ?? "";
            var mi = Array.IndexOf(MinorOrder, selectedSong.Key);
            if (mi >= 0) return MinorOrder[((mi + transposeSteps) % 12 + 12) % 12];
            var ki = Array.IndexOf(KeyOrder, selectedSong.Key);
            if (ki >= 0) return KeyOrder[((ki + transposeSteps) % 12 + 12) % 12];
            return selectedSong.Key;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadShellPreferencesAsync();
        await LoadAllSongs();
        if (UserState.IsLoggedIn)
        {
            await LoadUserData();
            await LoadSetlistsAsync();
        }

        if (SongId > 0)
        {
            await SelectSong(SongId);
            mobilePanelIndex = 2;
        }
        else
        {
            if (!string.IsNullOrWhiteSpace(activeSection))
                await SelectSection(activeSection, persistState: false);

            if (persistedSongId is > 0 && allSongs.Any(s => s.Id == persistedSongId.Value))
                await SelectSong(persistedSongId.Value, persistState: false);
        }
    }

    private async Task LoadShellPreferencesAsync()
    {
        try
        {
            var theme = await GetPreferenceAsync(PrefThemeKey);
            if (!string.IsNullOrWhiteSpace(theme) && (theme == "auto" || theme == "light" || theme == "dark"))
                appThemeMode = theme;

            var fontRaw = await GetPreferenceAsync(PrefFontSizeKey);
            if (int.TryParse(fontRaw, out var font))
                lyricsFontSize = Math.Clamp(font, 10, 32);

            var tab = await GetPreferenceAsync(PrefCategoryTabKey);
            if (tab is "New" or "Old" or "")
                categoryTab = tab;

            var section = await GetPreferenceAsync(PrefSectionKey);
            if (!string.IsNullOrWhiteSpace(section))
                activeSection = section;

            var panel = await GetPreferenceAsync(PrefPanelKey);
            if (int.TryParse(panel, out var panelValue))
                mobilePanelIndex = Math.Clamp(panelValue, 0, 2);

            persistedSongId = int.TryParse(await GetPreferenceAsync(PrefSongIdKey), out var id) ? id : (int?)null;
        }
        catch { }
    }

    private async Task<string?> GetPreferenceAsync(string key)
    {
        var keyJson = JsonSerializer.Serialize(key);
        return await JS.InvokeAsync<string?>("eval", $"localStorage.getItem({keyJson})");
    }

    private async Task SavePreferenceAsync(string key, string value)
    {
        var keyJson = JsonSerializer.Serialize(key);
        var valueJson = JsonSerializer.Serialize(value);
        await JS.InvokeVoidAsync("eval", $"localStorage.setItem({keyJson}, {valueJson})");
    }

    private async Task LoadAllSongs()
    {
        isLoading = true;
        try
        {
            allSongs = await Http.GetFromJsonAsync<List<SongItem>>("api/songs") ?? new();
            ApplyFilters();
        }
        catch { }
        finally { isLoading = false; }
    }

    private async Task LoadUserData()
    {
        try
        {
            var ud = await Http.GetFromJsonAsync<UserDataState>($"api/userdata/{UserState.UserId}");
            if (ud != null) userData = ud;
        }
        catch { }
    }

    private async Task LoadSetlistsAsync()
    {
        try
        {
            var global = await Http.GetFromJsonAsync<List<SetlistResponse>>("api/setlists/global") ?? new();
            var mine = await Http.GetFromJsonAsync<List<SetlistResponse>>("api/setlists/mine") ?? new();
            var smart = await Http.GetFromJsonAsync<List<SetlistResponse>>("api/setlists/smart") ?? new();

            globalSetlists = global.Select(s => new SetlistShellItem(s.Id, s.Name, s.Type, s.Songs?.Count ?? 0)).ToList();
            mySetlists = mine.Select(s => new SetlistShellItem(s.Id, s.Name, s.Type, s.Songs?.Count ?? 0)).ToList();
            smartSetlists = smart.Select(s => new SetlistShellItem(s.Id, s.Name, s.Type, s.Songs?.Count ?? 0)).ToList();
        }
        catch { }
    }

    private void ToggleSetlistFolder(string section)
    {
        activeSection = section;
        if (!expandedSetlistFolders.Add(section))
            expandedSetlistFolders.Remove(section);
    }

    private void SelectSetlistFolderItem(string section, string setlistId)
    {
        activeSection = section;
        selectedSetlistShellId = setlistId;
        mobilePanelIndex = 1;
        _ = SavePreferenceAsync(PrefSectionKey, section);
        _ = SavePreferenceAsync(PrefPanelKey, mobilePanelIndex.ToString());
    }

    private async Task SelectSection(string section, bool persistState = true)
    {
        activeSection = section;
        selectedSong = null;
        selectedSongId = null;
        selectedSetlistShellId = null;
        transposeSteps = 0;
        suggestedDrawerOpen = false;
        suggestedSongs = new();
        saveError = null;
        saveSuccess = false;
        newSong = new();
        ApplyFilters();
        mobilePanelIndex = 1;

        if (persistState)
        {
            await SavePreferenceAsync(PrefSectionKey, section);
            await SavePreferenceAsync(PrefSongIdKey, string.Empty);
            await SavePreferenceAsync(PrefPanelKey, mobilePanelIndex.ToString());
        }

        if (section == "favorites" && UserState.IsLoggedIn)
            await LoadUserData();
    }

    private async Task SelectSong(int id, bool persistState = true)
    {
        if (selectedSongId == id) return;
        selectedSongId = id;
        transposeSteps = 0;
        saveError = null;
        saveSuccess = false;
        isDetailLoading = true;
        mobilePanelIndex = 2;

        try
        {
            selectedSong = await Http.GetFromJsonAsync<SongDetail>($"api/songs/{id}");
            if (selectedSong != null && UserState.IsLoggedIn)
            {
                isFavorite = userData.Favorites.Contains(id);
                inNewSetlist = userData.NewSetlist.Contains(id);
                inOldSetlist = userData.OldSetlist.Contains(id);
            }
            if (persistState)
            {
                await SavePreferenceAsync(PrefSongIdKey, id.ToString());
                await SavePreferenceAsync(PrefPanelKey, mobilePanelIndex.ToString());
            }
            RefreshSuggestedSongs();
        }
        catch { selectedSong = null; }
        finally { isDetailLoading = false; }
    }

    private IEnumerable<SongItem> GetSectionBase()
    {
        return activeSection switch
        {
            "favorites" => allSongs.Where(s => userData.Favorites.Contains(s.Id)),
            _ => allSongs
        };
    }

    private void ApplyFilters()
    {
        var result = GetSectionBase();

        if (!string.IsNullOrWhiteSpace(searchText))
            result = result.Where(s =>
                s.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                (s.Singer?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));

        if (!string.IsNullOrEmpty(categoryTab))
            result = result.Where(s => s.Category == categoryTab);

        if (!string.IsNullOrEmpty(filterKey))
            result = result.Where(s => s.Key == filterKey);

        displayedSongs = result.ToList();
    }

    private void SetCategoryTab(string tab)
    {
        categoryTab = tab;
        _ = SavePreferenceAsync(PrefCategoryTabKey, tab);
        ApplyFilters();
    }

    private void OnKeyChanged(ChangeEventArgs e) { filterKey = e.Value?.ToString() ?? ""; ApplyFilters(); }
    private void ClearFilters() { filterKey = ""; searchText = ""; ApplyFilters(); }

    private void ToggleAppThemeMode()
    {
        appThemeMode = appThemeMode switch
        {
            "auto" => "dark",
            "dark" => "light",
            _ => "auto"
        };

        _ = SavePreferenceAsync(PrefThemeKey, appThemeMode);
    }

    private void RefreshSuggestedSongs()
    {
        if (selectedSong is null)
        {
            suggestedSongs = new();
            return;
        }

        var pool = allSongs.Where(s => s.Id != selectedSong.Id).ToList();
        var sameCategory = pool.Where(s => s.Category == selectedSong.Category).ToList();
        var keyMatch = sameCategory.Where(s => s.Key == selectedSong.Key).ToList();
        var others = sameCategory.Where(s => s.Key != selectedSong.Key).ToList();

        suggestedSongs = keyMatch.Concat(others.OrderBy(_ => Guid.NewGuid())).Take(12).ToList();

        if (suggestedSongs.Count < 6)
        {
            var extras = pool.Where(s => !suggestedSongs.Any(x => x.Id == s.Id))
                .OrderBy(_ => Guid.NewGuid())
                .Take(6 - suggestedSongs.Count);
            suggestedSongs.AddRange(extras);
        }
    }

