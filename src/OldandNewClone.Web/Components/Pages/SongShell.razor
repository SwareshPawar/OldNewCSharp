    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var targetSelector = GetActiveModalSelector();
        if (!string.Equals(targetSelector, activeFocusTrapSelector, StringComparison.Ordinal))
        {
            if (string.IsNullOrWhiteSpace(targetSelector))
                await DeactivateFocusTrapAsync();
            else
                await ActivateFocusTrapAsync(targetSelector);

            activeFocusTrapSelector = targetSelector;
        }

        // Restore scroll position after song fully loads
        if (_pendingScrollRestore && selectedSongId.HasValue && !isDetailLoading && _lastRenderedSongId != selectedSongId.Value)
        {
            _pendingScrollRestore = false;
            _lastRenderedSongId = selectedSongId.Value;
            await RestoreAndTrackScrollAsync(selectedSongId.Value);
        }
    }

