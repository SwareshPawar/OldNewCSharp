    private async Task SaveEditedSong()
    {
        saveError = null;
        if (string.IsNullOrWhiteSpace(editSong.Title)) { saveError = "Title is required."; return; }
        editSong.Tags = editTagsText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        isSaving = true;
        try
        {
            var dto = new { selectedSong!.Id, editSong.Title, editSong.Category, editSong.Key, editSong.Tempo, editSong.Time, editSong.Taal, editSong.Genres, editSong.Lyrics, editSong.Singer, editSong.Mood, editSong.Tags, editSong.Notes, editSong.YoutubeLink, editSong.SpotifyLink, IsPublic = true };
            var resp = await Http.PutAsJsonAsync($"api/songs/{selectedSong.Id}", dto);
            if (resp.IsSuccessStatusCode) { saveSuccess = true; await SelectSong(selectedSong.Id); await LoadAllSongs(); }
            else saveError = $"Save failed ({resp.StatusCode}).";
        }
        catch (Exception ex) { saveError = ex.Message; }
        finally { isSaving = false; }
    }

