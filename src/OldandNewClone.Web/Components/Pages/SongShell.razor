    // ── Edit ──
    private void ToggleEditMode()
    {
        isEditing = !isEditing;
        saveError = null;
        saveSuccess = false;
        if (isEditing && selectedSong is not null)
        {
            editSong = new SongFormModel
            {
                Title = selectedSong.Title, Category = selectedSong.Category,
                Key = selectedSong.Key, Tempo = selectedSong.Tempo,
                Time = selectedSong.Time, Taal = selectedSong.Taal,
