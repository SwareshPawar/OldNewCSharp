    private string editGenresText = "";
    private bool isSaving = false;
    private string? saveError;
    private bool saveSuccess = false;

    // ── Add mode ──
    private SongFormModel newSong = new();

    private static readonly string[] MusicKeys =
        { "C","C#","D","D#","E","F","F#","G","G#","A","A#","B",
          "Cm","C#m","Dm","D#m","Em","Fm","F#m","Gm","G#m","Am","A#m","Bm" };

    private static readonly string[] Moods =
        { "Worship","Praise","Reflective","Joyful","Peaceful","Energetic","Devotional" };

    // Tab counts
    private int NewTabCount => GetSectionBase().Count(s => s.Category == "New");
    private int OldTabCount => GetSectionBase().Count(s => s.Category == "Old");
    private int AllTabCount => GetSectionBase().Count();

    private bool HasFilters => !string.IsNullOrEmpty(filterKey);

    private string SectionTitle => activeSection switch
    {
        "favorites"  => "❤️ Favorites",
        "new"        => "✨ New Setlist",
        "old"        => "🕰️ Old Setlist",
        "add"        => "➕ Add Song",
        _            => "🎵 All Songs"
    };

    // ── Transpose ──
    private static readonly string[] KeyOrder  = { "C","C#","D","D#","E","F","F#","G","G#","A","A#","B" };
    private static readonly string[] MinorOrder = { "Cm","C#m","Dm","D#m","Em","Fm","F#m","Gm","G#m","Am","A#m","Bm" };

    private string TransposedKey
    {
        get
        {
            if (selectedSong == null || transposeSteps == 0) return selectedSong?.Key ?? "";
            var mi = Array.IndexOf(MinorOrder, selectedSong.Key);
            if (mi >= 0) return MinorOrder[((mi + transposeSteps) % 12 + 12) % 12];
            var ki = Array.IndexOf(KeyOrder, selectedSong.Key);
            if (ki >= 0) return KeyOrder[((ki + transposeSteps) % 12 + 12) % 12];
            return selectedSong.Key;
        }
    }

    // ── Lifecycle ──
    protected override async Task OnInitializedAsync()
    {
        await LoadAllSongs();
        if (UserState.IsLoggedIn) await LoadUserData();

        if (SongId > 0)
        {
            await SelectSong(SongId);
            mobilePanelIndex = 2;
        }
        else
        {
            mobilePanelIndex = 0;
        }
    }

    private async Task LoadAllSongs()
    {
        isLoading = true;
        try
        {
            allSongs = await Http.GetFromJsonAsync<List<SongItem>>("api/songs") ?? new();
            ApplyFilters();
        }
        catch { }
        finally { isLoading = false; }
    }

    private async Task LoadUserData()
    {
        try
        {
            var ud = await Http.GetFromJsonAsync<UserDataState>($"api/userdata/{UserState.UserId}");
            if (ud != null) userData = ud;
        }
        catch { }
    }

    // ── Section selection ──
    private async Task SelectSection(string section)
    {
        activeSection = section;
        selectedSong = null;
        selectedSongId = null;
        transposeSteps = 0;
        isEditing = false;
        saveError = null;
        saveSuccess = false;
        newSong = new();
        ApplyFilters();
        mobilePanelIndex = 1;

        if ((section == "favorites" || section == "new" || section == "old") && UserState.IsLoggedIn)
            await LoadUserData();
    }

    // ── Song selection ──
    private async Task SelectSong(int id)
    {
        if (selectedSongId == id) return;
        selectedSongId = id;
        transposeSteps = 0;
        isEditing = false;
        saveError = null;
        saveSuccess = false;
        isDetailLoading = true;
        mobilePanelIndex = 2;

        try
        {
            selectedSong = await Http.GetFromJsonAsync<SongDetail>($"api/songs/{id}");
            if (selectedSong != null && UserState.IsLoggedIn)
            {
                isFavorite = userData.Favorites.Contains(id);
                inNewSetlist = userData.NewSetlist.Contains(id);
                inOldSetlist = userData.OldSetlist.Contains(id);
            }
        }
        catch { selectedSong = null; }
        finally { isDetailLoading = false; }
    }

    // ── Section base (before tab/search/key filters) ──
    private IEnumerable<SongItem> GetSectionBase()
    {
        return activeSection switch
        {
            "favorites" => allSongs.Where(s => userData.Favorites.Contains(s.Id)),
            "new"       => allSongs.Where(s => userData.NewSetlist.Contains(s.Id)),
            "old"       => allSongs.Where(s => userData.OldSetlist.Contains(s.Id)),
            _           => allSongs
        };
    }

    // ── Filtering ──
    private void ApplyFilters()
    {
        var result = GetSectionBase();

        if (!string.IsNullOrWhiteSpace(searchText))
            result = result.Where(s =>
                s.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                (s.Singer?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));

        if (!string.IsNullOrEmpty(categoryTab))
            result = result.Where(s => s.Category == categoryTab);

        if (!string.IsNullOrEmpty(filterKey))
            result = result.Where(s => s.Key == filterKey);

        displayedSongs = result.ToList();
    }

    private void SetCategoryTab(string tab) { categoryTab = tab; ApplyFilters(); }
    private void OnKeyChanged(ChangeEventArgs e) { filterKey = e.Value?.ToString() ?? ""; ApplyFilters(); }
    private void ClearFilters() { filterKey = ""; searchText = ""; ApplyFilters(); }

    // ── Transpose ──
    private void TransposeUp() => transposeSteps++;
    private void TransposeDown() => transposeSteps--;
    private void ResetTranspose() => transposeSteps = 0;

    // ── Font Size ──
    private void IncreaseFontSize() => lyricsFontSize = Math.Min(lyricsFontSize + 2, 32);
    private void DecreaseFontSize() => lyricsFontSize = Math.Max(lyricsFontSize - 2, 10);

    // ── Auto Scroll ──
    private void ToggleAutoScroll()
    {
        if (isAutoScrolling)
        {
            _scrollCts?.Cancel();
            _scrollCts = null;
            isAutoScrolling = false;
        }
        else
        {
            isAutoScrolling = true;
            _scrollCts = new System.Threading.CancellationTokenSource();
            var token = _scrollCts.Token;
            _ = Task.Run(async () =>
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(50, token).ConfigureAwait(false);
                    await InvokeAsync(async () =>
                    {
                        await JS.InvokeVoidAsync("eval",
                            "document.getElementById('lyrics-scroll-panel')?.scrollBy(0, 1)");
                    });
                }
            }, token);
        }
    }

    // ── Favorite / Setlist ──
    private async Task ToggleFavorite()
    {
        if (!UserState.IsLoggedIn || selectedSongId is null) return;
        await Http.PostAsync($"api/userdata/{UserState.UserId}/favorites/{selectedSongId}", null);
        isFavorite = !isFavorite;
        if (isFavorite) userData.Favorites.Add(selectedSongId.Value);
        else userData.Favorites.Remove(selectedSongId.Value);
        ApplyFilters();
