    private void ResetSmartSetlistFilters()
    {
        smartSelectedCategories = new();
        smartSelectedKeys = new();
        smartSelectedMoods = new();
        smartSelectedGenres = new();
        smartSelectedTimes = new();
        smartSelectedTaals = new();
        smartSelectedSingers = new();
        smartSelectedTags = new();
        smartTempoMin = null;
        smartTempoMax = null;
        ResetSmartScanPreview();
    }

    private void LoadSmartSetlistFilters(Dictionary<string, string>? conditions)
    {
        ResetSmartSetlistFilters();
        if (conditions is null || conditions.Count == 0) return;

        smartSelectedCategories = ParseCsv(conditions, "categories");
        smartSelectedKeys = ParseCsv(conditions, "keys");
        smartSelectedMoods = ParseCsv(conditions, "moods");
        smartSelectedGenres = ParseCsv(conditions, "genres");
        smartSelectedTimes = ParseCsv(conditions, "times");
        smartSelectedTaals = ParseCsv(conditions, "taals");
        smartSelectedSingers = ParseCsv(conditions, "singers");
        smartSelectedTags = ParseCsv(conditions, "tags");
        conditions.TryGetValue("tempoMin", out smartTempoMin);
        conditions.TryGetValue("tempoMax", out smartTempoMax);
    }

    private Dictionary<string, string>? BuildSmartConditions()
    {
        var conditions = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        AddCsvCondition(conditions, "categories", smartSelectedCategories);
        AddCsvCondition(conditions, "keys", smartSelectedKeys);
        AddCsvCondition(conditions, "moods", smartSelectedMoods);
        AddCsvCondition(conditions, "genres", smartSelectedGenres);
        AddCsvCondition(conditions, "times", smartSelectedTimes);
        AddCsvCondition(conditions, "taals", smartSelectedTaals);
        AddCsvCondition(conditions, "singers", smartSelectedSingers);
        AddCsvCondition(conditions, "tags", smartSelectedTags);

        if (int.TryParse(smartTempoMin, out var tempoMin) && tempoMin > 0)
            conditions["tempoMin"] = tempoMin.ToString();
        if (int.TryParse(smartTempoMax, out var tempoMax) && tempoMax > 0)
            conditions["tempoMax"] = tempoMax.ToString();

        return conditions.Count == 0 ? null : conditions;
    }

    private static List<string> ParseCsv(Dictionary<string, string> conditions, string key)
    {
        if (!conditions.TryGetValue(key, out var raw) || string.IsNullOrWhiteSpace(raw)) return new();
        return raw
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static void AddCsvCondition(Dictionary<string, string> target, string key, List<string> values)
    {
        if (values.Count == 0) return;
        var normalized = values
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Select(v => v.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        if (normalized.Count > 0)
            target[key] = string.Join(",", normalized);
    }

    private void ResetSmartScanPreview()
    {
        isSmartScanRunning = false;
        smartScanHasRun = false;
        smartScanError = null;
        smartScanDiagnostics = null;
        smartScannedSongs = new();
    }

    private async Task<List<int>> FetchSmartScanSongIds(Dictionary<string, string>? conditions)
    {
        var payload = conditions ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var resp = await Http.PostAsJsonAsync("api/setlists/smart-scan", payload);
        if (!resp.IsSuccessStatusCode)
            throw new InvalidOperationException($"Smart scan failed ({resp.StatusCode}).");

        return await resp.Content.ReadFromJsonAsync<List<int>>() ?? new List<int>();
    }

    private async Task<List<int>> ResolveSmartScanSongIdsWithFallback(Dictionary<string, string>? conditions)
    {
        List<int> backendIds;
        try
        {
            backendIds = await FetchSmartScanSongIds(conditions);
        }
        catch (Exception ex)
        {
            backendIds = new List<int>();
            smartScanDiagnostics = $"backend scan unavailable ({ex.Message}); using local fallback";
        }

        // Fallback: if backend unexpectedly yields no matches, run local model filtering
        // to keep scan/create usable while backend mismatch is being diagnosed.
        if (backendIds.Count == 0)
        {
            if (allSongs.Count == 0)
                await LoadAllSongs();

            var localIds = ApplySmartConditionsForPreview(allSongs, conditions)
                .Select(s => s.Id)
                .Distinct()
                .ToList();

            if (localIds.Count > 0)
            {
                smartScanDiagnostics = $"backend matches: 0, local fallback matches: {localIds.Count}, loaded songs: {allSongs.Count}";
                return localIds;
            }
        }

        return backendIds;
    }

    private async Task ScanSmartSetlistSongsPreview()
    {
        smartScanError = null;
        smartScanDiagnostics = null;
        isSmartScanRunning = true;

        try
        {
            await Task.Yield();
            var conditions = BuildSmartConditions();

            var matchedIds = await ResolveSmartScanSongIdsWithFallback(conditions);

            if (allSongs.Count == 0)
                await LoadAllSongs();

            var idSet = matchedIds.ToHashSet();
            smartScannedSongs = allSongs
                .Where(s => idSet.Contains(s.Id))
                .OrderBy(s => s.Title, StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (string.IsNullOrWhiteSpace(smartScanDiagnostics))
                smartScanDiagnostics = $"backend matches: {matchedIds.Count}, loaded songs: {allSongs.Count}, rendered matches: {smartScannedSongs.Count}";
            smartScanHasRun = true;
        }
        catch (Exception ex)
        {
            smartScanError = ex.Message;
        }
        finally
        {
            isSmartScanRunning = false;
        }
    }

    private static List<SongItem> ApplySmartConditionsForPreview(List<SongItem> songs, Dictionary<string, string>? conditions)
    {
        if (conditions is null || conditions.Count == 0)
            return songs.OrderBy(s => s.Title).ToList();

        IEnumerable<SongItem> query = songs;

        var categories = ParseCsv(conditions, "categories");
        if (categories.Count > 0)
            query = query.Where(s => categories.Contains(s.Category, StringComparer.OrdinalIgnoreCase));

        var keys = ParseCsv(conditions, "keys");
        if (keys.Count > 0)
            query = query.Where(s => keys.Contains(s.Key, StringComparer.OrdinalIgnoreCase));

        var moods = ParseCsv(conditions, "moods");
        if (moods.Count > 0)
            query = query.Where(s => moods.Any(m => (s.Mood ?? string.Empty).Contains(m, StringComparison.OrdinalIgnoreCase)));

        var genres = ParseCsv(conditions, "genres");
        if (genres.Count > 0)
            query = query.Where(s => s.Genres.Any(g => genres.Contains(g, StringComparer.OrdinalIgnoreCase)));

        var times = ParseCsv(conditions, "times");
        if (times.Count > 0)
        {
            var normalizedTimes = times.Select(NormalizeMeter).Where(v => !string.IsNullOrWhiteSpace(v)).ToHashSet(StringComparer.OrdinalIgnoreCase);
            query = query.Where(s => !string.IsNullOrWhiteSpace(s.Time) && normalizedTimes.Contains(NormalizeMeter(s.Time)));
        }

        var taals = ParseCsv(conditions, "taals");
        if (taals.Count > 0)
        {
            var normalizedTaals = taals.Select(NormalizeTextToken).Where(v => !string.IsNullOrWhiteSpace(v)).ToHashSet(StringComparer.OrdinalIgnoreCase);
            query = query.Where(s => !string.IsNullOrWhiteSpace(s.Taal) && normalizedTaals.Contains(NormalizeTextToken(s.Taal)));
        }

        var singers = ParseCsv(conditions, "singers");
        if (singers.Count > 0)
            query = query.Where(s => !string.IsNullOrWhiteSpace(s.Singer) && singers.Contains(s.Singer!, StringComparer.OrdinalIgnoreCase));

        var tags = ParseCsv(conditions, "tags");
        if (tags.Count > 0)
            query = query.Where(s => s.Tags is not null && s.Tags.Any(t => tags.Contains(t, StringComparer.OrdinalIgnoreCase)));

        var tempoMin = 0;
        var tempoMax = 0;
        var hasTempoMin = conditions.TryGetValue("tempoMin", out var tempoMinRaw) && int.TryParse(tempoMinRaw, out tempoMin);
        var hasTempoMax = conditions.TryGetValue("tempoMax", out var tempoMaxRaw) && int.TryParse(tempoMaxRaw, out tempoMax);
        hasTempoMin = hasTempoMin && tempoMin > 0;
        hasTempoMax = hasTempoMax && tempoMax > 0;
        if (hasTempoMin || hasTempoMax)
        {
            query = query.Where(s => int.TryParse(s.Tempo, out var bpm) && (!hasTempoMin || bpm >= tempoMin) && (!hasTempoMax || bpm <= tempoMax));
        }

        return query
            .OrderBy(s => s.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string NormalizeMeter(string? meter)
    {
        if (string.IsNullOrWhiteSpace(meter)) return string.Empty;
        return meter.Trim().Replace(" ", string.Empty);
    }

    private static string NormalizeTextToken(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        return value.Trim();
    }

