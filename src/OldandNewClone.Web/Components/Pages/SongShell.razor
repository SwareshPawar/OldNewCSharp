    private async Task ToggleSelectedSongInSetlist()
    {
        if (!CanToggleSelectedSongInSetlist || selectedSongId is null || string.IsNullOrWhiteSpace(selectedActionSetlistId))
            return;

        isSetlistToggleBusy = true;
        setlistError = null;

        try
        {
            HttpResponseMessage resp = isSelectedSongInActionSetlist
