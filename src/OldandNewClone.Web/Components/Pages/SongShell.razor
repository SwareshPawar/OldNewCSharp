@page "/songs"
@page "/songs/{SongId:int}"
@layout EmptyLayout
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject OldandNewClone.Application.Services.UserStateService UserState
@inject IJSRuntime JS
@using System.Text.RegularExpressions
@using System.Text.Json

<PageTitle>🎵 OldandNew — Songs</PageTitle>

<div class="shell @AppThemeClass">

    <!-- PANEL 1 — Navigation Rail -->
    <div class="panel-1 @(mobilePanelIndex == 0 ? "mobile-show" : "mobile-hide")">
        <div class="p1-brand">
            <span class="brand-icon">🎵</span>
            <span class="brand-name">OldandNew</span>
        </div>

        <nav class="p1-nav">
            <div class="nav-section-label">LIBRARY</div>

            <button class="p1-nav-item @(activeSection == "all" ? "nav-active" : "")"
                    @onclick='() => SelectSection("all")'>
                <span class="nav-icon">🎵</span>
                <span class="nav-label">All Songs</span>
                <span class="nav-count">@allSongs.Count</span>
            </button>

            @if (UserState.IsLoggedIn)
            {
                <button class="p1-nav-item @(activeSection == "favorites" ? "nav-active" : "")"
                        @onclick='() => SelectSection("favorites")'>
                    <span class="nav-icon">❤️</span>
                    <span class="nav-label">Favorites</span>
                    <span class="nav-count">@userData.Favorites.Count</span>
                </button>
            }

            <div class="nav-section-label">SETLISTS</div>

            @if (UserState.IsLoggedIn)
            {
                <button class="p1-nav-item @(activeSection == "setlists-global" ? "nav-active" : "")"
                        @onclick='() => ToggleSetlistFolder("setlists-global")'>
                    <span class="nav-icon">@(expandedSetlistFolders.Contains("setlists-global") ? "📂" : "📁")</span>
                    <span class="nav-label">Global Setlists</span>
                    <span class="nav-count">@globalSetlists.Count</span>
                </button>
                @if (expandedSetlistFolders.Contains("setlists-global"))
                {
                    foreach (var item in globalSetlists)
                    {
                        <div class="setlist-row">
                            <button class="p1-nav-child-item @(selectedSetlistShellId == item.Id ? "nav-active" : "")"
                                    @onclick='async () => await SelectSetlistFolderItem("setlists-global", item.Id)'>
                                <span class="nav-icon">📄</span>
                                <span class="nav-label">@item.Name</span>
                                <span class="nav-count">@item.SongCount</span>
                            </button>

                            @if (UserState.IsAdmin)
                            {
                                <div class="setlist-actions">
                                    <button class="setlist-icon-btn" title="Edit setlist"
                                            @onclick='async () => await OpenEditSetlistModalFor("setlists-global", item.Id)'>✏️</button>
                                    <button class="setlist-icon-btn danger" title="Delete setlist"
                                            @onclick='async () => await DeleteSetlistFromPanel1("setlists-global", item.Id)'>🗑️</button>
                                </div>
                            }
                        </div>
                    }
                }

                <button class="p1-nav-item @(activeSection == "setlists-my" ? "nav-active" : "")"
                        @onclick='() => ToggleSetlistFolder("setlists-my")'>
                    <span class="nav-icon">@(expandedSetlistFolders.Contains("setlists-my") ? "📂" : "📁")</span>
                    <span class="nav-label">My Setlists</span>
                    <span class="nav-count">@mySetlists.Count</span>
                </button>
                @if (expandedSetlistFolders.Contains("setlists-my"))
                {
                    foreach (var item in mySetlists)
                    {
                        <div class="setlist-row">
                            <button class="p1-nav-child-item @(selectedSetlistShellId == item.Id ? "nav-active" : "")"
                                    @onclick='async () => await SelectSetlistFolderItem("setlists-my", item.Id)'>
                                <span class="nav-icon">📄</span>
                                <span class="nav-label">@item.Name</span>
                                <span class="nav-count">@item.SongCount</span>
                            </button>
                            <div class="setlist-actions">
                                <button class="setlist-icon-btn" title="Edit setlist"
                                        @onclick='async () => await OpenEditSetlistModalFor("setlists-my", item.Id)'>✏️</button>
                                <button class="setlist-icon-btn danger" title="Delete setlist"
                                        @onclick='async () => await DeleteSetlistFromPanel1("setlists-my", item.Id)'>🗑️</button>
                            </div>
                        </div>
                    }
                }

                <button class="p1-nav-item @(activeSection == "setlists-smart" ? "nav-active" : "")"
                        @onclick='() => ToggleSetlistFolder("setlists-smart")'>
                    <span class="nav-icon">@(expandedSetlistFolders.Contains("setlists-smart") ? "📂" : "📁")</span>
                    <span class="nav-label">Smart Setlists</span>
                    <span class="nav-count">@smartSetlists.Count</span>
                </button>
                @if (expandedSetlistFolders.Contains("setlists-smart"))
                {
                    foreach (var item in smartSetlists)
                    {
                        <div class="setlist-row">
                            <button class="p1-nav-child-item @(selectedSetlistShellId == item.Id ? "nav-active" : "")"
                                    @onclick='async () => await SelectSetlistFolderItem("setlists-smart", item.Id)'>
                                <span class="nav-icon">📄</span>
                                <span class="nav-label">@item.Name</span>
                                <span class="nav-count">@item.SongCount</span>
                            </button>
                            <div class="setlist-actions">
                                <button class="setlist-icon-btn" title="Sync smart setlist songs"
                                        @onclick='async () => await SyncSmartSetlist(item.Id)'>
                                    @(isSmartSetlistSyncing && syncingSmartSetlistId == item.Id ? "⏳" : "🔄")
                                </button>
                            </div>
                        </div>
                    }
                }
            }
        </nav>

        <div class="p1-footer">
            <button class="p1-nav-item p1-theme-btn" @onclick="ToggleAppThemeMode">
                <span class="nav-icon">🌓</span>
                <span class="nav-label">Theme: @AppThemeLabel</span>
            </button>

            @if (UserState.IsLoggedIn)
            {
                @if (CanCreateSetlist)
                {
                    <button class="p1-nav-item" @onclick="OpenCreateSetlistModal">
                        <span class="nav-icon">🗂️</span>
                        <span class="nav-label">New Setlist</span>
                    </button>
                }

                <button class="p1-nav-item" @onclick="OpenAddModal">
                    <span class="nav-icon">➕</span>
                    <span class="nav-label">Add Song</span>
                </button>
                <div class="p1-user" @onclick='() => Navigation.NavigateTo("/")'>
                    <div class="p1-avatar">@UserState.DisplayName[0].ToString().ToUpper()</div>
                    <div class="p1-user-info">
                        <span class="p1-username">@UserState.DisplayName</span>
                        @if (UserState.IsAdmin) { <span class="admin-dot">Admin</span> }
                    </div>
                </div>
            }
            else
            {
                <button class="p1-nav-item" @onclick='() => Navigation.NavigateTo("/auth/login")'>
                    <span class="nav-icon">≡ƒöæ</span>
                    <span class="nav-label">Sign In</span>
                </button>
            }
        </div>
    </div>

    <!-- PANEL 2 — Song List -->
    <div class="panel-2 @(mobilePanelIndex == 1 ? "mobile-show" : "mobile-hide")">
        <!-- P2 Header -->
        <div class="p2-header">
            <div class="p2-title-row">
                <button class="p2-back-btn" @onclick="MobileGoToPanel1" title="Back">‹</button>
                <h2 class="p2-title">@SectionTitle</h2>
                @if (CanManageSongsInSelectedSetlist)
                {
                    <button class="p2-manage-btn" title="Manage songs in setlist" @onclick="OpenManageSongsModal">🎵 Manage</button>
                }
            </div>

            <div class="p2-search-row">
                <input type="search" placeholder="🔍 Search songs, lyrics, taal..."
                       class="p2-search"
                       @bind="searchText" @bind:event="oninput" @onkeyup="ApplyFilters" />
            </div>

            <div class="p2-filter-row">
                <select class="p2-filter-select" @onchange="OnKeyChanged">
                    <option value="">All Keys</option>
                    @foreach (var k in MusicKeys)
                    {
                        <option value="@k">@k</option>
                    }
                </select>
                @if (HasFilters)
                {
                    <button class="p2-clear-btn" @onclick="ClearFilters" title="Clear filters">✕</button>
                }
            </div>

            <div class="p2-tabs">
                <button class="p2-tab @(categoryTab == "New" ? "p2-tab-active" : "")"
                        @onclick='() => SetCategoryTab("New")'>
                    ✨ New
                    <span class="p2-tab-count">@NewTabCount</span>
                </button>
                <button class="p2-tab @(categoryTab == "Old" ? "p2-tab-active" : "")"
                        @onclick='() => SetCategoryTab("Old")'>
                    🕰️ Old
                    <span class="p2-tab-count">@OldTabCount</span>
                </button>
                <button class="p2-tab @(categoryTab == "" ? "p2-tab-active" : "")"
                        @onclick='() => SetCategoryTab("")'>
                    All
                    <span class="p2-tab-count">@AllTabCount</span>
                </button>
            </div>
        </div>

        <!-- P2 Body -->
        <div class="p2-body">
            @if (isLoading)
            {
                <div class="p2-loading"><div class="spinner"></div></div>
            }
            else if (displayedSongs.Count == 0)
            {
                <div class="p2-empty">
                    <p>No songs found.</p>
                    @if (HasFilters || !string.IsNullOrEmpty(searchText))
                    {
                        <button @onclick="ClearFilters" class="p2-clear-all">Clear filters</button>
                    }
                </div>
            }
            else
            {
                @foreach (var song in displayedSongs)
                {
                    <div class="song-row @(selectedSongId == song.Id ? "song-row-active" : "")"
                         @onclick="() => SelectSong(song.Id)">
                        <div class="song-row-main">
                            <span class="song-row-title">@song.Title</span>
                            @if (!string.IsNullOrEmpty(song.Singer))
                            {
                                <span class="song-row-singer">🎤 @song.Singer</span>
                            }
                        </div>
                        <div class="song-row-right">
                            @if (!string.IsNullOrEmpty(song.Key))
                            {
                                <span class="key-pill">@song.Key</span>
                            }
                            <span class="cat-dot @(song.Category == "Old" ? "dot-old" : "dot-new")"></span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- PANEL 3 — Song Detail / Lyrics -->
    <div class="panel-3 @(mobilePanelIndex == 2 ? "mobile-show" : "mobile-hide")">
        @if (selectedSetlist is not null && selectedSong is null)
        {
            <div class="p3-empty">
                <div class="p3-empty-icon">📄</div>
                <p><strong>@selectedSetlist.Name</strong></p>
                <p>@SetlistSongCount songs • ✨ @SetlistNewCount New • 🕰️ @SetlistOldCount Old</p>
                <p>Select a song from Panel 2 to view lyrics</p>

                @if (SetlistSongCount > 0)
                {
                    <div style="width:100%; max-width:640px; text-align:left; margin-top:10px;">
                        @if (SetlistNewSongs.Count > 0)
                        {
                            <p><strong>✨ New (@SetlistNewSongs.Count)</strong></p>
                            <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:10px;">
                                @foreach (var song in SetlistNewSongs)
                                {
                                    <button class="action-btn" @onclick='async () => await SelectSong(song.Id)'>@song.Title</button>
                                }
                            </div>
                        }

                        @if (SetlistOldSongs.Count > 0)
                        {
                            <p><strong>🕰️ Old (@SetlistOldSongs.Count)</strong></p>
                            <div style="display:flex; flex-wrap:wrap; gap:8px;">
                                @foreach (var song in SetlistOldSongs)
                                {
                                    <button class="action-btn" @onclick='async () => await SelectSong(song.Id)'>@song.Title</button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (selectedSong is null)
        {
            <div class="p3-empty">
                <div class="p3-empty-icon">🎵</div>
                <p>Select a song to view its lyrics</p>
            </div>
        }
        else if (isDetailLoading)
        {
            <div class="p3-loading"><div class="spinner"></div></div>
        }
        else if (selectedSong is not null)
        {
            <div class="p3-content">
                <!-- P3 Top Bar -->
                <div class="p3-topbar">
                    <button class="p3-back-btn" @onclick="MobileGoToPanel2">‹ List</button>
                    <div class="p3-actions">
                        @if (UserState.IsLoggedIn)
                        {
                            <button class="action-btn @(isFavorite ? "action-fav-on" : "")"
                                    @onclick="ToggleFavorite" title="Favorite">
                                @(isFavorite ? "❤️" : "🤍")
                            </button>
                            <button class="action-btn @(inNewSetlist ? "action-set-on" : "")"
                                    @onclick="ToggleNewSetlist" title="Add to New Setlist">
                                @(inNewSetlist ? "✅" : "➕") New
                            </button>
                            <button class="action-btn @(inOldSetlist ? "action-set-on" : "")"
                                    @onclick="ToggleOldSetlist" title="Add to Old Setlist">
                                @(inOldSetlist ? "✅" : "➕") Old
                            </button>
                        }
                        <button class="action-btn" @onclick="ToggleSuggestedDrawer" title="Suggested songs">🎲 Suggestions</button>
                        <button class="action-btn" @onclick="DecreaseFontSize" title="Decrease font size">A−</button>
                        <button class="action-btn" @onclick="IncreaseFontSize" title="Increase font size">A+</button>
                        <button class="action-btn @(isAutoScrolling ? "action-scroll-on" : "")"
                                @onclick="ToggleAutoScroll" title="@(isAutoScrolling ? "Stop auto-scroll" : "Start auto-scroll")">
                            @(isAutoScrolling ? "⏸ Scroll" : "▶ Scroll")
                        </button>
                        <button class="action-btn action-edit" @onclick="OpenEditModal">✏️ Edit</button>
                    </div>
                </div>

                <div class="p3-meta">
                    <div class="p3-badges">
                        <span class="cat-badge @(selectedSong.Category == "Old" ? "badge-old" : "badge-new")">
                            @(selectedSong.Category == "Old" ? "🕰️ Old" : "✨ New")
                        </span>
                        @if (!string.IsNullOrEmpty(selectedSong.Mood))
                        {
                            <span class="mood-badge">@selectedSong.Mood</span>
                        }
                    </div>
                    <h1 class="p3-title">@selectedSong.Title</h1>
                    @if (!string.IsNullOrEmpty(selectedSong.Singer))
                    {
                        <p class="p3-singer">🎤 @selectedSong.Singer</p>
                    }
                    <div class="p3-info-chips">
                        <span class="info-chip">🎼 <strong>@TransposedKey</strong></span>
                        @if (!string.IsNullOrEmpty(selectedSong.Tempo)) { <span class="info-chip">⏱ @selectedSong.Tempo BPM</span> }
                        @if (!string.IsNullOrEmpty(selectedSong.Time)) { <span class="info-chip">🕒 @selectedSong.Time</span> }
                        @if (!string.IsNullOrEmpty(selectedSong.Taal)) { <span class="info-chip">🥁 @selectedSong.Taal</span> }
                    </div>
                    @if (selectedSong.Genres.Any())
                    {
                        <div class="genre-chips">
                            @foreach (var g in selectedSong.Genres)
                            {
                                <span class="genre-chip">@g</span>
                            }
                        </div>
                    }
                </div>

                <div class="transpose-bar">
                    <span class="transpose-label">🎹 Transpose</span>
                    <button @onclick="TransposeDown" class="transpose-btn">−</button>
                    <span class="transpose-display">
                        @if (transposeSteps == 0) { <span>Original</span> }
                        else { <span>@(transposeSteps > 0 ? $"+{transposeSteps}" : $"{transposeSteps}") semitones</span> }
                    </span>
                    <button @onclick="TransposeUp" class="transpose-btn">+</button>
                    @if (transposeSteps != 0)
                    {
                        <button @onclick="ResetTranspose" class="btn-reset-t">↺ Reset</button>
                    }
                </div>

                @if (!string.IsNullOrEmpty(selectedSong.YoutubeLink) || !string.IsNullOrEmpty(selectedSong.SpotifyLink))
                {
                    <div class="ext-links">
                        @if (!string.IsNullOrEmpty(selectedSong.YoutubeLink))
                        {
                            <a href="@selectedSong.YoutubeLink" target="_blank" class="link-yt">▶ YouTube</a>
                        }
                        @if (!string.IsNullOrEmpty(selectedSong.SpotifyLink))
                        {
                            <a href="@selectedSong.SpotifyLink" target="_blank" class="link-sp">🎧 Spotify</a>
                        }
                    </div>
                }

                <div class="lyrics-section" id="lyrics-scroll-panel">
                    <h3 class="section-heading">📄 Lyrics</h3>
                    @if (string.IsNullOrWhiteSpace(selectedSong.Lyrics))
                    {
                        <p class="no-content">No lyrics available.</p>
                    }
                    else
                    {
                        <pre class="lyrics-body" style="font-size: @(lyricsFontSize)px;">@(new Microsoft.AspNetCore.Components.MarkupString(RenderLyricsWithChords(selectedSong.Lyrics, transposeSteps)))</pre>
                    }
                </div>

                @if (!string.IsNullOrEmpty(selectedSong.Notes))
                {
                    <div class="notes-section">
                        <h3 class="section-heading">📝 Notes</h3>
                        <p class="notes-body">@selectedSong.Notes</p>
                    </div>
                }

                @if (selectedSong.Tags != null && selectedSong.Tags.Any())
                {
                    <div class="tags-row">
                        <span class="tags-label">🏷️</span>
                        @foreach (var tag in selectedSong.Tags) { <span class="tag-chip">@tag</span> }
                    </div>
                }
            </div>

            @if (suggestedDrawerOpen)
            {
                <div class="suggested-overlay" @onclick="CloseSuggestedDrawer"></div>
                <aside class="suggested-drawer">
                    <div class="suggested-header">
                        <h4>🎲 Suggested Songs</h4>
                        <button class="suggested-close" @onclick="CloseSuggestedDrawer">✕</button>
                    </div>
                    @if (suggestedSongs.Count == 0)
                    {
                        <div class="suggested-empty">No suggestions available.</div>
                    }
                    else
                    {
                        <div class="suggested-list">
                            @foreach (var s in suggestedSongs)
                            {
                                <button class="suggested-item" @onclick="() => SelectSuggestedSong(s.Id)">
                                    <span class="suggested-title">@s.Title</span>
                                    <span class="suggested-meta">@s.Category • @s.Key</span>
                                </button>
                            }
                        </div>
                    }
                </aside>
            }
        }
    </div>
</div>

@if (showSongModal)
{
    <div class="song-modal-overlay" @onclick="CloseSongModal"></div>
    <div class="song-modal-container" role="dialog" aria-modal="true">
        <div class="song-modal-header">
            <h3>@(isEditModal ? "✏️ Edit Song" : "➕ Add Song")</h3>
            <button class="song-modal-close" @onclick="CloseSongModal">✕</button>
        </div>

        <div class="song-modal-body">
            @if (saveError != null)
            {
                <div class="form-error">⚠️ @saveError</div>
            }
            @if (saveSuccess)
            {
                <div class="form-success">✅ Saved successfully!</div>
            }

            @if (isEditModal)
            {
                <div class="form-group"><label>Title *</label><input @bind="editSong.Title" class="form-input" /></div>
                <div class="form-row-2">
                    <div class="form-group"><label>Category</label>
                        <select @bind="editSong.Category" class="form-select">
                            <option value="Old">Old</option><option value="New">New</option>
                        </select>
                    </div>
                    <div class="form-group"><label>Key</label>
                        <select @bind="editSong.Key" class="form-select">
                            <option value="">--</option>
                            @foreach (var k in MusicKeys) { <option value="@k">@k</option> }
                        </select>
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group"><label>Singer</label><input @bind="editSong.Singer" class="form-input" /></div>
                    <div class="form-group"><label>Mood</label>
                        <select @bind="editSong.Mood" class="form-select">
                            <option value="">--</option>
                            @foreach (var m in Moods) { <option value="@m">@m</option> }
                        </select>
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group"><label>Tempo (BPM)</label><input @bind="editSong.Tempo" class="form-input" /></div>
                    <div class="form-group"><label>Time</label>
                        <select @bind="editSong.Time" class="form-select">
                            <option value="">--</option>
                            @foreach (var t in TimeOptions) { <option value="@t">@t</option> }
                        </select>
                    </div>
                </div>
                <div class="form-group"><label>Taal</label>
                    <select @bind="editSong.Taal" class="form-select">
                        <option value="">--</option>
                        @foreach (var taal in TaalOptions) { <option value="@taal">@taal</option> }
                    </select>
                </div>
                <div class="form-group"><label>Genres</label>
                    <div class="multi-option-grid">
                        @foreach (var g in GenreOptions)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@editSong.Genres.Contains(g)"
                                       @onchange="e => SetGenreSelection(editSong.Genres, g, IsChecked(e))" />
                                <span>@g</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="form-group"><label>Tags (comma separated)</label><input @bind="editTagsText" class="form-input" /></div>
                <div class="form-group"><label>Lyrics</label><textarea @bind="editSong.Lyrics" class="form-textarea" rows="9"></textarea></div>
                <div class="form-group"><label>Notes</label><input @bind="editSong.Notes" class="form-input" /></div>
                <div class="form-row-2">
                    <div class="form-group"><label>YouTube Link</label><input @bind="editSong.YoutubeLink" class="form-input" type="url" /></div>
                    <div class="form-group"><label>Spotify Link</label><input @bind="editSong.SpotifyLink" class="form-input" type="url" /></div>
                </div>
            }
            else
            {
                <div class="form-group"><label>Title *</label><input @bind="newSong.Title" class="form-input" placeholder="Song title" /></div>
                <div class="form-row-2">
                    <div class="form-group"><label>Category *</label>
                        <select @bind="newSong.Category" class="form-select">
                            <option value="">--</option><option value="Old">Old</option><option value="New">New</option>
                        </select>
                    </div>
                    <div class="form-group"><label>Key</label>
                        <select @bind="newSong.Key" class="form-select">
                            <option value="">--</option>
                            @foreach (var k in MusicKeys) { <option value="@k">@k</option> }
                        </select>
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group"><label>Singer</label><input @bind="newSong.Singer" class="form-input" placeholder="Singer name" /></div>
                    <div class="form-group"><label>Mood</label>
                        <select @bind="newSong.Mood" class="form-select">
                            <option value="">--</option>
                            @foreach (var m in Moods) { <option value="@m">@m</option> }
                        </select>
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group"><label>Tempo (BPM)</label><input @bind="newSong.Tempo" class="form-input" placeholder="120" /></div>
                    <div class="form-group"><label>Time</label>
                        <select @bind="newSong.Time" class="form-select">
                            <option value="">--</option>
                            @foreach (var t in TimeOptions) { <option value="@t">@t</option> }
                        </select>
                    </div>
                </div>
                <div class="form-group"><label>Taal</label>
                    <select @bind="newSong.Taal" class="form-select">
                        <option value="">--</option>
                        @foreach (var taal in TaalOptions) { <option value="@taal">@taal</option> }
                    </select>
                </div>
                <div class="form-group"><label>Genres</label>
                    <div class="multi-option-grid">
                        @foreach (var g in GenreOptions)
                        {
                            <label class="multi-option-item">
                                <input type="checkbox"
                                       checked="@newSong.Genres.Contains(g)"
                                       @onchange="e => SetGenreSelection(newSong.Genres, g, IsChecked(e))" />
                                <span>@g</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="form-group"><label>Tags (comma separated)</label><input @bind="newTagsText" class="form-input" placeholder="Evening, Communion" /></div>
            }
        </div>

        <div class="song-modal-actions">
            @if (isEditModal && UserState.IsAdmin)
            {
                <button @onclick="DeleteSong" class="btn-delete" disabled="@isSaving">🗑️ Delete</button>
            }
            <button @onclick="CloseSongModal" class="btn-cancel-edit">Cancel</button>
            <button @onclick="SaveSongFromModal" class="btn-save-song" disabled="@isSaving">
                @(isSaving ? "Saving..." : "💾 Save")
            </button>
        </div>
    </div>
}


@if (showSetlistModal)
{
    <div class="song-modal-overlay" @onclick="CloseSetlistModal"></div>
    <div class="song-modal-container" role="dialog" aria-modal="true">
        <div class="song-modal-header">
            <h3>@(isEditSetlistModal ? "✏️ Edit Setlist" : "🗂️ New Setlist")</h3>
            <button class="song-modal-close" @onclick="CloseSetlistModal">✕</button>
        </div>

        <div class="song-modal-body">
            @if (setlistError != null)
            {
                <div class="form-error">⚠️ @setlistError</div>
            }

            <div class="form-group"><label>Name *</label><input @bind="setlistName" class="form-input" /></div>
            <div class="form-group"><label>Description</label><textarea @bind="setlistDescription" class="form-textarea" rows="4"></textarea></div>
        </div>

        <div class="song-modal-actions">
            <button @onclick="CloseSetlistModal" class="btn-cancel-edit">Cancel</button>
            <button @onclick="SaveSetlistFromModal" class="btn-save-song" disabled="@isSetlistSaving">
                @(isSetlistSaving ? "Saving..." : "💾 Save")
            </button>
        </div>
    </div>
}

@if (showManageSongsModal)
{
    <div class="song-modal-overlay" @onclick="CloseManageSongsModal"></div>
    <div class="song-modal-container manage-songs-modal" role="dialog" aria-modal="true">
        <div class="song-modal-header">
            <h3>🎵 Manage Songs — @selectedSetlist?.Name</h3>
            <button class="song-modal-close" @onclick="CloseManageSongsModal">✕</button>
        </div>

        <div class="manage-songs-body">
            @if (manageSongsError != null)
            {
                <div class="form-error">⚠️ @manageSongsError</div>
            }

            <!-- Current setlist songs -->
            <div class="manage-section-label">
                <span>IN SETLIST <span class="manage-count-badge">@manageSongsList.Count</span></span>
            </div>
            @if (manageSongsList.Count == 0)
            {
                <div class="manage-empty-hint">No songs yet. Add some below.</div>
            }
            else
            {
                <div class="manage-setlist-songs">
                    @for (int i = 0; i < manageSongsList.Count; i++)
                    {
                        var idx = i;
                        var song = allSongs.FirstOrDefault(s => s.Id == manageSongsList[idx]);
                        if (song is null) continue;
                        <div class="manage-song-row">
                            <div class="manage-reorder-btns">
                                <button class="manage-order-btn" title="Move up" disabled="@(idx == 0)"
                                        @onclick="() => ManageSongsMoveUp(idx)">↑</button>
                                <button class="manage-order-btn" title="Move down" disabled="@(idx == manageSongsList.Count - 1)"
                                        @onclick="() => ManageSongsMoveDown(idx)">↓</button>
                            </div>
                            <div class="manage-song-info">
                                <span class="manage-song-title">@song.Title</span>
                                @if (!string.IsNullOrEmpty(song.Singer))
                                {
                                    <span class="manage-song-meta">🎤 @song.Singer</span>
                                }
                            </div>
                            <div class="manage-song-right">
                                @if (!string.IsNullOrEmpty(song.Key))
                                {
                                    <span class="key-pill">@song.Key</span>
                                }
                                <span class="cat-dot @(song.Category == "Old" ? "dot-old" : "dot-new")"></span>
                                <button class="manage-remove-btn" title="Remove from setlist"
                                        @onclick="() => ManageSongsRemove(song.Id)">🗑️</button>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Add songs section -->
            <div class="manage-section-label" style="margin-top:14px;">
                <span>ADD SONGS</span>
            </div>
            <input type="search" placeholder="🔍 Search to add..."
                   class="p2-search manage-add-search"
                   @bind="manageSongsSearchText" @bind:event="oninput" />

            <div class="manage-add-list">
                @{
                    var available = allSongs
                        .Where(s => !manageSongsList.Contains(s.Id))
                        .Where(s => string.IsNullOrEmpty(manageSongsSearchText) ||
                                    s.Title.Contains(manageSongsSearchText, StringComparison.OrdinalIgnoreCase) ||
                                    (s.Singer?.Contains(manageSongsSearchText, StringComparison.OrdinalIgnoreCase) ?? false))
                        .OrderBy(s => s.Title)
                        .ToList();
                }
                @if (!available.Any())
                {
                    <div class="manage-empty-hint">No songs match your search.</div>
                }
                @foreach (var song in available)
                {
                    <div class="manage-song-row manage-add-row">
                        <div class="manage-song-info">
                            <span class="manage-song-title">@song.Title</span>
                            @if (!string.IsNullOrEmpty(song.Singer))
                            {
                                <span class="manage-song-meta">🎤 @song.Singer</span>
                            }
                        </div>
                        <div class="manage-song-right">
                            @if (!string.IsNullOrEmpty(song.Key))
                            {
                                <span class="key-pill">@song.Key</span>
                            }
                            <span class="cat-dot @(song.Category == "Old" ? "dot-old" : "dot-new")"></span>
                            <button class="manage-add-btn" title="Add to setlist"
                                    @onclick="() => ManageSongsAdd(song.Id)">➕</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="song-modal-actions">
            <button @onclick="CloseManageSongsModal" class="btn-cancel-edit">Cancel</button>
            <button @onclick="SaveManageSongs" class="btn-save-song" disabled="@isManageSongsSaving">
                @(isManageSongsSaving ? "Saving..." : "💾 Save")
            </button>
        </div>
    </div>
}
<!-- STYLES -->
<style>
