    .shell.theme-dark .song-row-active { background: #1e3a8a !important; }
    .shell.theme-dark .p2-search,
    .shell.theme-dark .p2-filter-select,
    .shell.theme-dark .form-input,
    .shell.theme-dark .form-select,
    .shell.theme-dark .form-textarea,
