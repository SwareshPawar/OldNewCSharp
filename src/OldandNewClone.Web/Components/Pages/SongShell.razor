    private async Task SaveSetlistFromModal()
    {
        setlistError = null;
        if (string.IsNullOrWhiteSpace(setlistName))
        {
            setlistError = "Setlist name is required.";
            return;
        }

        isSetlistSaving = true;
        try
        {
            var smartConditions = IsSmartSetlistModal ? BuildSmartConditions() : null;
            var smartSongsForSave = IsSmartSetlistModal
                ? await ResolveSmartScanSongIdsWithFallback(smartConditions)
                : new List<int>();

            if (isEditSetlistModal && selectedSetlist is not null)
            {
                var updateDto = new
                {
                    Name = setlistName.Trim(),
                    Description = setlistDescription,
                    Songs = IsSmartSetlistModal ? smartSongsForSave : selectedSetlist.Songs,
                    Conditions = IsSmartSetlistModal ? smartConditions : selectedSetlist.Conditions,
                    IsPublic = selectedSetlist.IsPublic
                };

                var updateResp = await Http.PutAsJsonAsync($"api/setlists/{selectedSetlist.Id}", updateDto);
                if (!updateResp.IsSuccessStatusCode)
                {
                    setlistError = $"Save failed ({updateResp.StatusCode}).";
                    return;
                }

                if (IsSmartSetlistModal)
                {
                    var syncResp = await Http.PostAsync($"api/setlists/{selectedSetlist.Id}/sync", null);
                    if (!syncResp.IsSuccessStatusCode)
                    {
                        setlistError = $"Saved, but sync failed ({syncResp.StatusCode}).";
                    }
                }
            }
            else
            {
                var type = activeSection switch
                {
                    "setlists-global" => "global",
                    "setlists-smart" => "smart",
                    _ => "my"
                };
                var createDto = new
                {
                    Name = setlistName.Trim(),
                    Description = setlistDescription,
                    Type = type,
                    Songs = type == "smart" ? smartSongsForSave : new List<int>(),
                    Conditions = type == "smart" ? smartConditions : null,
                    IsPublic = type == "global"
                };

                var createResp = await Http.PostAsJsonAsync("api/setlists", createDto);
                if (!createResp.IsSuccessStatusCode)
                {
                    setlistError = $"Create failed ({createResp.StatusCode}).";
                    return;
                }

                var created = await createResp.Content.ReadFromJsonAsync<SetlistResponse>();
                if (created is not null && string.Equals(created.Type, "smart", StringComparison.OrdinalIgnoreCase))
                {
                    var syncResp = await Http.PostAsync($"api/setlists/{created.Id}/sync", null);
                    if (!syncResp.IsSuccessStatusCode)
                    {
                        setlistError = $"Created, but sync failed ({syncResp.StatusCode}).";
                    }
                }

                await LoadSetlistsAsync();
                if (created is not null)
                {
                    var createdSection = created.Type switch
                    {
                        "global" => "setlists-global",
                        "smart" => "setlists-smart",
                        _ => "setlists-my"
                    };
                    await SelectSetlistFolderItem(createdSection, created.Id);
                }

                CloseSetlistModal();
                return;
            }

            await LoadSetlistsAsync();
            if (selectedSetlistShellId is not null)
                await SelectSetlistFolderItem(activeSection, selectedSetlistShellId);

            CloseSetlistModal();
        }
        catch (Exception ex)
        {
            setlistError = ex.Message;
        }
        finally
        {
            isSetlistSaving = false;
        }
    }

