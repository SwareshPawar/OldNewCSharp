        if (string.IsNullOrWhiteSpace(newSong.Category)) { saveError = "Category is required."; return; }
        isSaving = true;
        try
        {
            var dto = new { newSong.Title, newSong.Category, newSong.Key, newSong.Tempo, newSong.Time, newSong.Taal, Genres = new List<string>(), newSong.Lyrics, newSong.Singer, newSong.Notes, IsPublic = true };
            var resp = await Http.PostAsJsonAsync("api/songs", dto);
            if (resp.IsSuccessStatusCode) { saveSuccess = true; newSong = new(); await LoadAllSongs(); await SelectSection("all"); }
            else saveError = $"Save failed ({resp.StatusCode}).";
        }
        catch (Exception ex) { saveError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task DeleteSong()
    {
        if (selectedSong is null) return;
        isSaving = true;
        try
        {
            var resp = await Http.DeleteAsync($"api/songs/{selectedSong.Id}");
            if (resp.IsSuccessStatusCode) { selectedSong = null; selectedSongId = null; await LoadAllSongs(); mobilePanelIndex = 1; }
            else saveError = "Delete failed.";
        }
        catch (Exception ex) { saveError = ex.Message; }
        finally { isSaving = false; }
    }

    // ── Chord Transposition Engine (mirrors original app's transposeChord logic) ──
    private static readonly string[] ChordRoots =
        { "C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B" };

    private static readonly Dictionary<string, string> FlatToSharp = new()
    {
        {"Db","C#"},{"Eb","D#"},{"Fb","E"},{"Gb","F#"},{"Ab","G#"},{"Bb","A#"},{"Cb","B"}
    };

    // Matches full chord symbols: C, Am, G#maj7, Bb/F, etc.
    private static readonly Regex ChordRegex = new(
        @"([A-G][#b]?)(maj7?|min|m7?|dim|aug|sus[24]?|add9|m9|maj9|7|9|11|13|6)?(?:\/([A-G][#b]?))?",
        RegexOptions.Compiled);

    // Matches a whole line that is only chords + spaces
    private static readonly Regex ChordLineRegex = new(
        @"^(\s*[A-G][#b]?(?:maj7?|min|m7?|dim|aug|sus[24]?|add9|m9|maj9|7|9|11|13|6)?(?:\/[A-G][#b]?)?\s*)+$",
        RegexOptions.Compiled | RegexOptions.IgnoreCase);

    // Matches [Chord] inline markers: [Am], [G#7], etc.
    private static readonly Regex InlineChordRegex = new(
        @"\[([A-G][#b]?(?:maj7?|min|m7?|dim|aug|sus[24]?|add9|m9|maj9|7|9|11|13|6)?(?:\/[A-G][#b]?)?)\]",
        RegexOptions.Compiled);

    private static string TransposeSingleRoot(string root, int steps)
    {
        if (FlatToSharp.TryGetValue(root, out var sharp)) root = sharp;
        var idx = Array.IndexOf(ChordRoots, root);
        if (idx < 0) return root;
        return ChordRoots[((idx + steps) % 12 + 12) % 12];
    }

    private static string TransposeChordSymbol(string chord, int steps)
    {
        if (steps == 0) return chord;
        return ChordRegex.Replace(chord, m =>
        {
            var root = TransposeSingleRoot(m.Groups[1].Value, steps);
            var quality = m.Groups[2].Value;
            var bass = m.Groups[3].Success
                ? "/" + TransposeSingleRoot(m.Groups[3].Value, steps)
                : "";
            return root + quality + bass;
        });
    }

    private static string RenderLyricsWithChords(string lyrics, int steps)
    {
        if (string.IsNullOrWhiteSpace(lyrics))
            return System.Web.HttpUtility.HtmlEncode(lyrics);

        var sb = new System.Text.StringBuilder();
        foreach (var rawLine in lyrics.Split('\n'))
        {
            var line = rawLine.TrimEnd('\r');

            // 1. Inline [Chord] markers
            if (InlineChordRegex.IsMatch(line))
            {
                var escaped = System.Web.HttpUtility.HtmlEncode(
                    InlineChordRegex.Replace(line, m => $"\x01{m.Groups[1].Value}\x02"));
                escaped = escaped
                    .Replace("\x01", "<span class=\"inline-chord\">[")
                    .Replace("\x02", steps == 0
                        ? "]</span>"
                        : $" → {System.Web.HttpUtility.HtmlEncode(TransposeChordSymbol(
                            line[line.IndexOf('[')..(line.IndexOf(']') + 1)], steps))}]</span>");

                // Simpler: re-process properly
                var rendered = InlineChordRegex.Replace(
                    System.Web.HttpUtility.HtmlEncode(line),
                    m =>
                    {
                        var orig = m.Groups[1].Value;
                        var transposed = TransposeChordSymbol(orig, steps);
                        return $"<span class=\"inline-chord\">[{System.Web.HttpUtility.HtmlEncode(transposed)}]</span>";
                    });
                sb.AppendLine(rendered);
                continue;
            }

            // 2. Chord-only line
            if (!string.IsNullOrWhiteSpace(line) && ChordLineRegex.IsMatch(line.Trim()))
            {
                var transposed = steps == 0 ? line
                    : ChordRegex.Replace(line, m =>
                    {
                        if (!m.Success || string.IsNullOrEmpty(m.Groups[1].Value)) return m.Value;
                        return TransposeChordSymbol(m.Value, steps);
                    });
                sb.AppendLine($"<span class=\"chord-line\">{System.Web.HttpUtility.HtmlEncode(transposed)}</span>");
                continue;
            }

            // 3. Plain lyric line
            sb.AppendLine(System.Web.HttpUtility.HtmlEncode(line));
        }
        return sb.ToString();
    }

