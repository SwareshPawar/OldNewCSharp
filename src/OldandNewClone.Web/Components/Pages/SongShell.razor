    private async Task ToggleNewSetlist()
    {
        if (!UserState.IsLoggedIn || selectedSongId is null) return;
        await Http.PostAsync($"api/userdata/{UserState.UserId}/new-setlist/{selectedSongId}", null);
        inNewSetlist = !inNewSetlist;
        if (inNewSetlist) userData.NewSetlist.Add(selectedSongId.Value);
        else userData.NewSetlist.Remove(selectedSongId.Value);
        ApplyFilters();
    }

    private async Task ToggleOldSetlist()
    {
        if (!UserState.IsLoggedIn || selectedSongId is null) return;
        await Http.PostAsync($"api/userdata/{UserState.UserId}/old-setlist/{selectedSongId}", null);
