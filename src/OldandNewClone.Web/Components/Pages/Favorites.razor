@page "/favorites"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject OldandNewClone.Application.Services.UserStateService UserState

<PageTitle>❤️ My Favorites</PageTitle>

<div class="favorites-container">
    <div class="page-header">
        <h1>❤️ My Favorites</h1>
        <a href="/songs" class="btn-browse">🎵 Browse Songs</a>
    </div>

    @if (!UserState.IsLoggedIn)
    {
        <div class="auth-prompt">
            <p>🔒 Please <a href="/auth/login">log in</a> to view your favorites.</p>
        </div>
    }
    else if (isLoading)
    {
        <div class="loading-state"><div class="spinner"></div><p>Loading favorites...</p></div>
    }
    else if (errorMessage != null)
    {
        <div class="error-state">⚠️ @errorMessage</div>
    }
    else if (favoriteSongs.Count == 0)
    {
        <div class="empty-state">
            <p>💔 No favorites yet.</p>
            <p>Go to the <a href="/songs">Song Library</a> and tap ❤️ on any song.</p>
        </div>
    }
    else
    {
        <p class="count-label">@favoriteSongs.Count song@(favoriteSongs.Count == 1 ? "" : "s") saved</p>
        <div class="songs-grid">
            @foreach (var song in favoriteSongs)
            {
                <div class="song-card">
                    <div class="song-card-header">
                        <span class="category-badge @(song.Category == "Old" ? "badge-old" : "badge-new")">
                            @(song.Category == "Old" ? "🕰️ Old" : "✨ New")
                        </span>
                        <span class="song-key">🎼 @song.Key</span>
                    </div>
                    <h3 class="song-title">@song.Title</h3>
                    @if (!string.IsNullOrEmpty(song.Singer))
                    {
                        <p class="song-singer">🎤 @song.Singer</p>
                    }
                    <div class="card-actions">
                        <button class="btn-view" @onclick="() => NavigateToSong(song.Id)">👁 View</button>
                        <button class="btn-remove" @onclick="() => RemoveFavorite(song.Id)">💔 Remove</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .favorites-container { max-width: 1100px; margin: 0 auto; padding: 20px; font-family: 'Segoe UI', sans-serif; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .page-header h1 { margin: 0; color: #2c3e50; }
    .btn-browse { background: #3498db; color: white; padding: 9px 18px; border-radius: 8px; text-decoration: none; font-weight: 600; }
    .btn-browse:hover { background: #2980b9; }
    .count-label { color: #7f8c8d; margin-bottom: 16px; }

    .songs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 18px; }
    .song-card { background: white; border-radius: 12px; padding: 18px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .song-card-header { display: flex; justify-content: space-between; margin-bottom: 8px; }
    .category-badge { padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
    .badge-old { background: #fef3cd; color: #856404; }
    .badge-new { background: #d1ecf1; color: #0c5460; }
    .song-key { font-size: 0.85rem; color: #7f8c8d; }
    .song-title { margin: 0 0 6px; color: #2c3e50; font-size: 1rem; font-weight: 700; }
    .song-singer { margin: 0 0 12px; color: #7f8c8d; font-size: 0.88rem; }
    .card-actions { display: flex; gap: 8px; }
    .btn-view { flex: 1; background: #3498db; color: white; border: none; padding: 7px; border-radius: 6px; cursor: pointer; font-size: 0.85rem; }
    .btn-view:hover { background: #2980b9; }
    .btn-remove { flex: 1; background: #e74c3c; color: white; border: none; padding: 7px; border-radius: 6px; cursor: pointer; font-size: 0.85rem; }
    .btn-remove:hover { background: #c0392b; }

    .auth-prompt, .empty-state, .error-state { text-align: center; padding: 60px 20px; color: #7f8c8d; }
    .auth-prompt a, .empty-state a { color: #3498db; }
    .loading-state { text-align: center; padding: 60px 20px; color: #7f8c8d; }
    .spinner { width: 40px; height: 40px; border: 4px solid #e0e0e0; border-top-color: #3498db; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16px; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private List<FavoriteSongItem> favoriteSongs = new();
    private bool isLoading = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (UserState.IsLoggedIn)
            await LoadFavorites();
    }

    private async Task LoadFavorites()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            // Get user data (favorites list of song IDs)
            var userData = await Http.GetFromJsonAsync<UserDataResponse>(
                $"api/userdata/{UserState.UserId}");

            if (userData?.Favorites == null || userData.Favorites.Count == 0)
            {
                favoriteSongs = new();
                return;
            }

            // Get all songs and filter to favorites
            var allSongs = await Http.GetFromJsonAsync<List<FavoriteSongItem>>("api/songs");
            favoriteSongs = allSongs?
                .Where(s => userData.Favorites.Contains(s.Id))
                .ToList() ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load favorites: {ex.Message}";
        }
        finally { isLoading = false; }
    }

    private async Task RemoveFavorite(int songId)
    {
        try
        {
            await Http.PostAsync($"api/userdata/{UserState.UserId}/favorites/{songId}", null);
            favoriteSongs.RemoveAll(s => s.Id == songId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to remove: {ex.Message}";
        }
    }

    private void NavigateToSong(int id) => Navigation.NavigateTo($"/songs/{id}");

    private record FavoriteSongItem(int Id, string Title, string Category, string Key,
        List<string> Genres, string? Singer, string? Mood);

    private class UserDataResponse
    {
        public List<int> Favorites { get; set; } = new();
        public List<int> NewSetlist { get; set; } = new();
        public List<int> OldSetlist { get; set; } = new();
    }
}
