@page "/songs"
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="mobile-page-content">
    <!-- Header -->
    <div class="page-header">
        <h1>🎵 Song Library</h1>
        <span class="count-badge">@filteredSongs.Count</span>
    </div>

    <!-- Search -->
    <div class="search-bar">
        <input type="search" placeholder="🔍 Search songs..."
               @bind="searchText" @bind:event="oninput" @onkeyup="ApplyFilters"
               class="search-input" />
    </div>

    <!-- Filter Chips -->
    <div class="filter-chips">
        <button class="chip @(selectedCategory == "" ? "chip-active" : "")" @onclick='() => SetCategory("")'>All</button>
        <button class="chip @(selectedCategory == "New" ? "chip-active" : "")" @onclick='() => SetCategory("New")'>✨ New</button>
        <button class="chip @(selectedCategory == "Old" ? "chip-active" : "")" @onclick='() => SetCategory("Old")'>🕰️ Old</button>
    </div>

    <!-- Content -->
    @if (isLoading)
    {
        <div class="loading-state"><div class="spinner"></div><p>Loading songs...</p></div>
    }
    else if (errorMessage != null)
    {
        <div class="error-state">
            <p>⚠️ @errorMessage</p>
            <button @onclick="LoadSongs" class="btn-retry">Retry</button>
        </div>
    }
    else if (filteredSongs.Count == 0)
    {
        <div class="empty-state">
            <p>🎵 No songs found.</p>
            @if (!string.IsNullOrEmpty(searchText) || !string.IsNullOrEmpty(selectedCategory))
            {
                <button @onclick="ClearFilters" class="btn-retry">Clear Filters</button>
            }
        </div>
    }
    else
    {
        <div class="song-list">
            @foreach (var song in PagedSongs)
            {
                <div class="song-item" @onclick="() => NavigateToSong(song.Id)">
                    <div class="song-item-main">
                        <span class="song-item-title">@song.Title</span>
                        @if (!string.IsNullOrEmpty(song.Singer))
                        {
                            <span class="song-item-singer">🎤 @song.Singer</span>
                        }
                    </div>
                    <div class="song-item-right">
                        <span class="key-chip">@song.Key</span>
                        <span class="category-dot @(song.Category == "Old" ? "dot-old" : "dot-new")"></span>
                        <span class="chevron">›</span>
                    </div>
                </div>
            }
        </div>

        @if (TotalPages > 1)
        {
            <div class="pagination">
                <button @onclick="() => GoToPage(currentPage - 1)" disabled="@(currentPage == 1)" class="page-btn">‹</button>
                <span class="page-info">@currentPage / @TotalPages</span>
                <button @onclick="() => GoToPage(currentPage + 1)" disabled="@(currentPage == TotalPages)" class="page-btn">›</button>
            </div>
        }
    }
</div>

<style>
    .mobile-page-content { padding: 16px; max-width: 600px; margin: 0 auto; font-family: 'Segoe UI', sans-serif; }
    .page-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
    .page-header h1 { margin: 0; font-size: 1.5rem; color: #2c3e50; }
    .count-badge { background: #3498db; color: white; border-radius: 12px; padding: 2px 10px; font-size: 0.8rem; font-weight: 700; }

    .search-bar { margin-bottom: 12px; }
    .search-input { width: 100%; padding: 13px 16px; border: 2px solid #e0e0e0; border-radius: 14px; font-size: 1rem; box-sizing: border-box; }
    .search-input:focus { outline: none; border-color: #3498db; }

    .filter-chips { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
    .chip { padding: 7px 16px; border: 2px solid #e0e0e0; border-radius: 20px; background: white; cursor: pointer; font-size: 0.85rem; font-weight: 600; color: #555; transition: all 0.2s; }
    .chip:hover { border-color: #3498db; color: #3498db; }
    .chip-active { background: #3498db; border-color: #3498db; color: white; }

    .song-list { display: flex; flex-direction: column; gap: 2px; }
    .song-item { display: flex; justify-content: space-between; align-items: center; background: white; padding: 16px; border-radius: 12px; cursor: pointer; transition: background 0.15s; border: 1px solid #f0f0f0; }
    .song-item:hover, .song-item:active { background: #f0f8ff; }
    .song-item-main { display: flex; flex-direction: column; gap: 3px; flex: 1; min-width: 0; }
    .song-item-title { font-weight: 700; color: #2c3e50; font-size: 0.98rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .song-item-singer { font-size: 0.8rem; color: #7f8c8d; }
    .song-item-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .key-chip { background: #eaf4fb; color: #1a5276; padding: 3px 9px; border-radius: 10px; font-size: 0.78rem; font-weight: 700; }
    .category-dot { width: 8px; height: 8px; border-radius: 50%; }
    .dot-old { background: #f39c12; }
    .dot-new { background: #27ae60; }
    .chevron { color: #bdc3c7; font-size: 1.4rem; font-weight: 300; }

    .pagination { display: flex; justify-content: center; align-items: center; gap: 20px; padding: 20px 0; }
    .page-btn { background: #3498db; color: white; border: none; width: 40px; height: 40px; border-radius: 10px; cursor: pointer; font-size: 1.3rem; }
    .page-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .page-info { font-weight: 600; color: #555; }

    .loading-state, .empty-state, .error-state { text-align: center; padding: 50px 20px; color: #7f8c8d; }
    .spinner { width: 40px; height: 40px; border: 4px solid #e0e0e0; border-top-color: #3498db; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 14px; }
    .btn-retry { background: #3498db; color: white; border: none; padding: 10px 22px; border-radius: 10px; cursor: pointer; margin-top: 10px; font-size: 0.9rem; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private List<SongItem> allSongs = new();
    private List<SongItem> filteredSongs = new();
    private bool isLoading = true;
    private string? errorMessage;
    private string searchText = "";
    private string selectedCategory = "";
    private int currentPage = 1;
    private const int PageSize = 20;

    private int TotalPages => (int)Math.Ceiling(filteredSongs.Count / (double)PageSize);
    private List<SongItem> PagedSongs =>
        filteredSongs.Skip((currentPage - 1) * PageSize).Take(PageSize).ToList();

    protected override async Task OnInitializedAsync() => await LoadSongs();

    private async Task LoadSongs()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            allSongs = await Http.GetFromJsonAsync<List<SongItem>>("api/songs") ?? new();
            ApplyFilters();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; }
    }

    private void ApplyFilters()
    {
        var result = allSongs.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchText))
            result = result.Where(s =>
                s.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                (s.Singer?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));

        if (!string.IsNullOrEmpty(selectedCategory))
            result = result.Where(s => s.Category == selectedCategory);

        filteredSongs = result.ToList();
        currentPage = 1;
    }

    private void SetCategory(string cat) { selectedCategory = cat; ApplyFilters(); }
    private void ClearFilters() { searchText = ""; selectedCategory = ""; ApplyFilters(); }
    private void GoToPage(int p) { if (p >= 1 && p <= TotalPages) currentPage = p; }
    private void NavigateToSong(int id) => Navigation.NavigateTo($"/songs/{id}");

    private record SongItem(int Id, string Title, string Category, string Key,
        List<string> Genres, string? Singer, string? Mood);
}
