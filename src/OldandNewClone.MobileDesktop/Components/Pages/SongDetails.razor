@page "/songs/{Id:int}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UserStateService UserState

<div class="mobile-page-content">
    @if (isLoading)
    {
        <div class="loading-state"><div class="spinner"></div><p>Loading...</p></div>
    }
    else if (song == null)
    {
        <div class="error-state"><p>⚠️ Song not found.</p><a href="/songs">← Back</a></div>
    }
    else
    {
        <!-- Top Bar -->
        <div class="top-bar">
            <button @onclick='() => Navigation.NavigateTo("/songs")' class="btn-back">←</button>
            <div class="top-actions">
                @if (UserState.IsLoggedIn)
                {
                    <button class="action-btn @(isFavorite ? "action-active-red" : "")"
                            @onclick="ToggleFavorite">
                        @(isFavorite ? "❤️" : "🤍")
                    </button>
                }
                <a href="/songs/@song.Id/edit" class="action-btn">✏️</a>
            </div>
        </div>

        <!-- Song Card -->
        <div class="song-header-card">
            <div class="badges-row">
                <span class="cat-badge @(song.Category == "Old" ? "badge-old" : "badge-new")">
                    @(song.Category == "Old" ? "🕰️ Old" : "✨ New")
                </span>
                @if (!string.IsNullOrEmpty(song.Mood))
                {
                    <span class="mood-badge">@song.Mood</span>
                }
            </div>
            <h1 class="song-title">@song.Title</h1>
            @if (!string.IsNullOrEmpty(song.Singer))
            {
                <p class="song-singer">🎤 @song.Singer</p>
            }

            <!-- Info row -->
            <div class="info-row">
                <div class="info-chip">🎼 <strong>@TransposedKey</strong></div>
                @if (!string.IsNullOrEmpty(song.Tempo)) { <div class="info-chip">⏱ @song.Tempo BPM</div> }
                @if (!string.IsNullOrEmpty(song.Time)) { <div class="info-chip">@song.Time</div> }
            </div>

            <!-- Transpose -->
            <div class="transpose-row">
                <span class="transpose-label">🎹 Transpose</span>
                <button @onclick="TransposeDown" class="transpose-btn">−</button>
                <span class="transpose-val">@(transposeSteps == 0 ? "0" : transposeSteps > 0 ? $"+{transposeSteps}" : $"{transposeSteps}")</span>
                <button @onclick="TransposeUp" class="transpose-btn">+</button>
                @if (transposeSteps != 0)
                {
                    <button @onclick="ResetTranspose" class="btn-reset">↺</button>
                }
            </div>

            <!-- Setlist buttons -->
            @if (UserState.IsLoggedIn)
            {
                <div class="setlist-row">
                    <button class="setlist-btn @(inNewSetlist ? "setlist-active" : "")"
                            @onclick="ToggleNewSetlist">
                        @(inNewSetlist ? "✅" : "➕") New Setlist
                    </button>
                    <button class="setlist-btn @(inOldSetlist ? "setlist-active" : "")"
                            @onclick="ToggleOldSetlist">
                        @(inOldSetlist ? "✅" : "➕") Old Setlist
                    </button>
                </div>
            }

            <!-- External Links -->
            @if (!string.IsNullOrEmpty(song.YoutubeLink) || !string.IsNullOrEmpty(song.SpotifyLink))
            {
                <div class="links-row">
                    @if (!string.IsNullOrEmpty(song.YoutubeLink))
                    {
                        <a href="@song.YoutubeLink" target="_blank" class="link-yt">▶ YouTube</a>
                    }
                    @if (!string.IsNullOrEmpty(song.SpotifyLink))
                    {
                        <a href="@song.SpotifyLink" target="_blank" class="link-sp">🎧 Spotify</a>
                    }
                </div>
            }
        </div>

        <!-- Lyrics -->
        <div class="lyrics-card">
            <h2>📄 Lyrics</h2>
            @if (string.IsNullOrWhiteSpace(song.Lyrics))
            {
                <p class="no-lyrics">No lyrics available.</p>
            }
            else
            {
                <pre class="lyrics-text">@song.Lyrics</pre>
            }
        </div>

        @if (!string.IsNullOrEmpty(song.Notes))
        {
            <div class="notes-card">
                <h2>📝 Notes</h2>
                <p>@song.Notes</p>
            </div>
        }
    }
</div>

<style>
    .mobile-page-content { padding: 12px; max-width: 600px; margin: 0 auto; font-family: 'Segoe UI', sans-serif; }
    .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
    .btn-back { background: #ecf0f1; border: none; width: 42px; height: 42px; border-radius: 12px; font-size: 1.3rem; cursor: pointer; }
    .top-actions { display: flex; gap: 8px; }
    .action-btn { background: #ecf0f1; border: none; width: 42px; height: 42px; border-radius: 12px; font-size: 1.1rem; cursor: pointer; text-decoration: none; display: flex; align-items: center; justify-content: center; }
    .action-active-red { background: #fdecea; }

    .song-header-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); margin-bottom: 14px; }
    .badges-row { display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
    .cat-badge { padding: 4px 12px; border-radius: 16px; font-size: 0.78rem; font-weight: 700; }
    .badge-old { background: #fef3cd; color: #856404; }
    .badge-new { background: #d1ecf1; color: #0c5460; }
    .mood-badge { background: #f8f4ff; color: #6c3483; padding: 4px 12px; border-radius: 16px; font-size: 0.78rem; font-weight: 700; }
    .song-title { margin: 0 0 6px; font-size: 1.5rem; font-weight: 800; color: #2c3e50; }
    .song-singer { margin: 0 0 12px; color: #7f8c8d; font-size: 0.9rem; }
    .info-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
    .info-chip { background: #f0f8ff; color: #1a5276; padding: 5px 12px; border-radius: 12px; font-size: 0.83rem; }

    .transpose-row { display: flex; align-items: center; gap: 10px; background: #f8f9fa; padding: 12px; border-radius: 12px; margin-bottom: 12px; }
    .transpose-label { font-weight: 600; font-size: 0.85rem; color: #555; flex: 1; }
    .transpose-btn { background: #3498db; color: white; border: none; width: 36px; height: 36px; border-radius: 10px; font-size: 1.2rem; font-weight: 700; cursor: pointer; }
    .transpose-val { font-weight: 700; min-width: 36px; text-align: center; color: #2c3e50; }
    .btn-reset { background: #e74c3c; color: white; border: none; padding: 6px 10px; border-radius: 8px; cursor: pointer; font-size: 0.8rem; }

    .setlist-row { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
    .setlist-btn { flex: 1; background: #ecf0f1; border: 2px solid #e0e0e0; padding: 10px; border-radius: 10px; cursor: pointer; font-size: 0.85rem; font-weight: 600; color: #555; transition: all 0.2s; min-width: 120px; }
    .setlist-active { background: #d5f5e3; border-color: #27ae60; color: #1e8449; }

    .links-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .link-yt { background: #e74c3c; color: white; padding: 8px 14px; border-radius: 10px; text-decoration: none; font-size: 0.85rem; font-weight: 600; }
    .link-sp { background: #1db954; color: white; padding: 8px 14px; border-radius: 10px; text-decoration: none; font-size: 0.85rem; font-weight: 600; }

    .lyrics-card, .notes-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); margin-bottom: 14px; }
    .lyrics-card h2, .notes-card h2 { margin: 0 0 14px; font-size: 1rem; color: #2c3e50; border-bottom: 2px solid #ecf0f1; padding-bottom: 8px; }
    .lyrics-text { white-space: pre-wrap; font-family: 'Georgia', serif; font-size: 0.98rem; line-height: 2; color: #2c3e50; margin: 0; }
    .no-lyrics { color: #95a5a6; font-style: italic; }

    .loading-state, .error-state { text-align: center; padding: 60px 20px; color: #7f8c8d; }
    .spinner { width: 40px; height: 40px; border: 4px solid #e0e0e0; border-top-color: #3498db; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 14px; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private SongDetailDto? song;
    private bool isLoading = true;
    private int transposeSteps = 0;
    private bool isFavorite = false;
    private bool inNewSetlist = false;
    private bool inOldSetlist = false;

    private static readonly string[] Keys =
        { "C","C#","D","D#","E","F","F#","G","G#","A","A#","B" };
    private static readonly string[] MinorKeys =
        { "Cm","C#m","Dm","D#m","Em","Fm","F#m","Gm","G#m","Am","A#m","Bm" };

    private string TransposedKey
    {
        get
        {
            if (song == null || transposeSteps == 0) return song?.Key ?? "";
            var mi = Array.IndexOf(MinorKeys, song.Key);
            if (mi >= 0) return MinorKeys[((mi + transposeSteps) % 12 + 12) % 12];
            var ki = Array.IndexOf(Keys, song.Key);
            if (ki >= 0) return Keys[((ki + transposeSteps) % 12 + 12) % 12];
            return song.Key;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            song = await Http.GetFromJsonAsync<SongDetailDto>($"api/songs/{Id}");
            if (UserState.IsLoggedIn) await LoadUserState();
        }
        catch { song = null; }
        finally { isLoading = false; }
    }

    private async Task LoadUserState()
    {
        try
        {
            var ud = await Http.GetFromJsonAsync<UserData>($"api/userdata/{UserState.UserId}");
            if (ud != null)
            {
                isFavorite = ud.Favorites.Contains(Id);
                inNewSetlist = ud.NewSetlist.Contains(Id);
                inOldSetlist = ud.OldSetlist.Contains(Id);
            }
        }
        catch { }
    }

    private void TransposeUp() => transposeSteps++;
    private void TransposeDown() => transposeSteps--;
    private void ResetTranspose() => transposeSteps = 0;

    private async Task ToggleFavorite()
    {
        await Http.PostAsync($"api/userdata/{UserState.UserId}/favorites/{Id}", null);
        isFavorite = !isFavorite;
    }
    private async Task ToggleNewSetlist()
    {
        await Http.PostAsync($"api/userdata/{UserState.UserId}/new-setlist/{Id}", null);
        inNewSetlist = !inNewSetlist;
    }
    private async Task ToggleOldSetlist()
    {
        await Http.PostAsync($"api/userdata/{UserState.UserId}/old-setlist/{Id}", null);
        inOldSetlist = !inOldSetlist;
    }

    private record SongDetailDto(int Id, string Title, string Category, string Key,
        string Tempo, string Time, string Taal, List<string> Genres, string Lyrics,
        string? Singer, string? Mood, List<string>? Tags, string? YoutubeLink,
        string? SpotifyLink, string? Notes, bool IsPublic, int ViewCount,
        DateTime CreatedAt, DateTime? UpdatedAt);

    private class UserData
    {
        public List<int> Favorites { get; set; } = new();
        public List<int> NewSetlist { get; set; } = new();
        public List<int> OldSetlist { get; set; } = new();
    }
}
